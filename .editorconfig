root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.cs]
indent_style = space
indent_size = 4
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = false

csharp_style_namespace_declarations = block_scoped:suggestion
csharp_style_var_for_built_in_types = false:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = false:suggestion
csharp_prefer_braces = true:suggestion
csharp_style_expression_bodied_methods = false:suggestion
csharp_style_expression_bodied_properties = true:suggestion

dotnet_style_qualification_for_field = false:suggestion
dotnet_style_qualification_for_property = false:suggestion
dotnet_style_qualification_for_method = false:suggestion
dotnet_style_qualification_for_event = false:suggestion

dotnet_style_require_accessibility_modifiers = for_non_interface_members:suggestion
dotnet_style_predefined_type_for_locals_parameters_members = true:suggestion
dotnet_style_predefined_type_for_member_access = true:suggestion
dotnet_style_object_initializer = true:suggestion
dotnet_style_collection_initializer = true:suggestion
dotnet_style_coalesce_expression = true:suggestion
dotnet_style_null_propagation = true:suggestion

# Keep the default build signal-bearing. Directory.Build.props baselines specific,
# reviewed legacy diagnostics. Do not suppress whole analyzer categories here: doing so
# would also hide new security, reliability, and usage findings.

dotnet_diagnostic.CA1416.severity = warning
dotnet_diagnostic.CA2000.severity = warning
dotnet_diagnostic.CA2201.severity = warning
dotnet_diagnostic.CA2213.severity = warning
dotnet_diagnostic.CA1031.severity = silent
dotnet_diagnostic.IDE0005.severity = silent

[tests/**/*.cs]
# Short-lived test doubles and synchronization probes intentionally use process-lifetime
# cleanup in several synchronous tests. Keep ownership diagnostics active in production.
dotnet_diagnostic.CA2000.severity = none
# Cancellation-token tests deliberately decide whether to observe or ignore the callback
# token at each wait point.
dotnet_diagnostic.CA2016.severity = none

[*.{csproj,props,targets,xaml,xml,config}]
indent_style = space
indent_size = 2

[*.{json,yml,yaml,md,html,css,js,ps1}]
indent_style = space
indent_size = 2
