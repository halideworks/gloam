<UserControl x:Class="HDRGammaController.NightModeScheduleControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="480">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Gloam;component/Themes/Brutalist.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Title/Summary -->
            <RowDefinition Height="180"/>  <!-- Graph -->
            <RowDefinition Height="Auto"/> <!-- Toolbar -->
            <RowDefinition Height="Auto"/>    <!-- List -->
        </Grid.RowDefinitions>

        <!-- Summary and Location -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Background="Transparent" Foreground="{DynamicResource ThemeTextDim}"
                       FontFamily="{DynamicResource BodyFont}" FontSize="12" TextWrapping="Wrap" VerticalAlignment="Center">
                Drag points to adjust. Double-click to add.
            </TextBlock>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                 <Button x:Name="DetectBtn" Content="AUTO-DETECT LOCATION" Click="Detect_Click"
                         FontSize="11" Padding="12,6" Margin="0,0,10,0"/>

                 <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                     <TextBlock Text="LAT" Style="{StaticResource FieldLabel}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                     <TextBox Text="{Binding LatitudeText, UpdateSourceTrigger=PropertyChanged}" Width="56"
                              Padding="5,3" FontSize="11" LostFocus="Location_LostFocus"/>
                     <TextBlock Text="LON" Style="{StaticResource FieldLabel}" VerticalAlignment="Center" Margin="10,0,4,0"/>
                     <TextBox Text="{Binding LongitudeText, UpdateSourceTrigger=PropertyChanged}" Width="56"
                              Padding="5,3" FontSize="11" LostFocus="Location_LostFocus"/>
                 </StackPanel>
            </StackPanel>
        </Grid>

        <!-- Graph Container -->
        <Border Grid.Row="1" Background="{DynamicResource ThemeBg}" BorderBrush="{DynamicResource ThemeBorder}"
                BorderThickness="2" Margin="0,0,0,8">
            <Grid>
                 <Canvas x:Name="GridCanvas" IsHitTestVisible="False"/>
                 <Canvas x:Name="CurveCanvas" ClipToBounds="True" Background="Transparent"
                        MouseLeftButtonDown="GraphCanvas_MouseDown"
                        MouseMove="GraphCanvas_MouseMove"
                        MouseLeftButtonUp="GraphCanvas_MouseUp"
                        SizeChanged="GraphCanvas_SizeChanged"/>

                 <!-- Drag Readout Popup (In-Canvas Overlay) -->
                 <Border x:Name="DragOverlay" HorizontalAlignment="Left" VerticalAlignment="Top"
                         Background="{DynamicResource ThemeSurface}" BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="2"
                         Padding="8" IsHitTestVisible="False"
                         Visibility="{Binding IsDragOverlayVisible, Converter={StaticResource BoolToVis}}">
                     <StackPanel>
                         <TextBlock Text="{Binding OverlayTimeText}" Foreground="{DynamicResource ThemeText}"
                                    FontFamily="{DynamicResource MonoFont}" FontWeight="Bold"/>
                         <TextBlock Text="{Binding OverlayTempText}" Foreground="{DynamicResource ThemeAccent}"
                                    FontFamily="{DynamicResource MonoFont}"/>
                     </StackPanel>
                 </Border>
            </Grid>
        </Border>

        <!-- Toolbar -->
        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Button Content="ADD POINT" Click="AddPoint_Click" Padding="12,6" Margin="0,0,8,0"/>
                <Button Content="RESET DEFAULT" Click="Reset_Click" Padding="12,6"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <CheckBox IsChecked="{Binding UseUltraWarmMode}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Foreground="{DynamicResource ThemeText}" FontFamily="{DynamicResource BodyFont}"
                           FontSize="12" VerticalAlignment="Center">
                    <Run Text="Ultra Warm" FontWeight="Bold"/>
                    <Run Text=" - Enhanced warmth below 2800K" Foreground="{DynamicResource ThemeTextDim}"/>
                </TextBlock>
            </StackPanel>
        </Grid>

        <!-- List -->
        <DataGrid ItemsSource="{Binding Points}" SelectedItem="{Binding SelectedPoint}"
                  Grid.Row="3" Background="{DynamicResource ThemeBg}" BorderThickness="0"
                  AutoGenerateColumns="False" CanUserAddRows="False" HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="{DynamicResource ThemeTrack}"
                  RowBackground="Transparent" Foreground="{DynamicResource ThemeText}"
                  FontFamily="{DynamicResource BodyFont}"
                  VerticalScrollBarVisibility="Disabled">
            <DataGrid.Resources>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="{DynamicResource ThemeSurface}"/>
                    <Setter Property="Foreground" Value="{DynamicResource ThemeTextDim}"/>
                    <Setter Property="FontFamily" Value="{DynamicResource DisplayFont}"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="FontSize" Value="11"/>
                    <Setter Property="Padding" Value="8,6"/>
                    <Setter Property="BorderThickness" Value="0,0,2,2"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorder}"/>
                </Style>
                <Style TargetType="DataGridCell">
                    <Setter Property="Padding" Value="6,4"/>
                    <Setter Property="Foreground" Value="{DynamicResource ThemeText}"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="DataGridCell">
                                <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}" BorderThickness="0">
                                    <ContentPresenter VerticalAlignment="Center" />
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{DynamicResource ThemeAccent}"/>
                            <Setter Property="Foreground" Value="{DynamicResource ThemeOnAccent}"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.Resources>

            <DataGrid.Columns>
                <!-- Trigger Type -->
                <DataGridTemplateColumn Header="TYPE" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding TriggerType}" Foreground="{DynamicResource ThemeText}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <ComboBox SelectedItem="{Binding TriggerType}" ItemsSource="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=Vm.TriggerTypes}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <!-- Time / Offset -->
                <DataGridTemplateColumn Header="TIME/OFFSET" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DisplayTime}" FontFamily="{DynamicResource MonoFont}" Foreground="{DynamicResource ThemeText}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding DisplayTime, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <!-- Temp -->
                <DataGridTemplateColumn Header="TEMP (K)" Width="74">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding TargetKelvin}" FontFamily="{DynamicResource MonoFont}" FontWeight="Bold" Foreground="{DynamicResource ThemeText}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                             <TextBox Text="{Binding TargetKelvin, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <!-- Fade -->
                <DataGridTemplateColumn Header="FADE (M)" Width="64">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding FadeMinutes}" FontFamily="{DynamicResource MonoFont}" Foreground="{DynamicResource ThemeText}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding FadeMinutes, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <!-- Delete -->
                <DataGridTemplateColumn Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="DELETE" Click="DeleteRow_Click" Padding="10,4"
                                    FontSize="10" HorizontalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
