<Window x:Class="HDRGammaController.CalibrationSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Calibration Setup"
        Height="540" Width="480"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E"
        Foreground="White"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize">

    <Window.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#0078D4"/>
        <SolidColorBrush x:Key="CardBackground" Color="#2D2D2D"/>
        <SolidColorBrush x:Key="CardBorder" Color="#3F3F3F"/>
        <SolidColorBrush x:Key="TextDim" Color="#888888"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#22C55E"/>
        <SolidColorBrush x:Key="WarningBrush" Color="#F59E0B"/>
        <SolidColorBrush x:Key="ErrorBrush" Color="#EF4444"/>

        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#3D3D3D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
        </Style>

        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>
    </Window.Resources>

    <Border Background="#1E1E1E" BorderBrush="#3F3F3F" BorderThickness="1" CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" Background="#252525" CornerRadius="8,8,0,0" MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid Margin="16,0">
                    <TextBlock Text="Display Calibration Setup" VerticalAlignment="Center" FontWeight="Medium" FontSize="14"/>
                    <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Center"
                            Background="Transparent" Foreground="#888" Padding="8,4"
                            Click="Close_Click"/>
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,16">
                <StackPanel>
                    <!-- Intro -->
                    <TextBlock Text="Configure your colorimeter calibration settings below."
                               Foreground="{StaticResource TextDim}" TextWrapping="Wrap" Margin="0,0,0,20"/>

                    <!-- Monitor Selection -->
                    <TextBlock Text="Select Monitor" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                    <ComboBox x:Name="MonitorComboBox" Margin="0,0,0,20"/>

                    <!-- Calibration Target -->
                    <TextBlock Text="Calibration Target" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                    <Border Background="{StaticResource CardBackground}" CornerRadius="6" Padding="12" Margin="0,0,0,20">
                        <StackPanel>
                            <RadioButton x:Name="Target709G22" Content="Rec.709 Gamma 2.2 (sRGB)" IsChecked="True" GroupName="Target"/>
                            <RadioButton x:Name="Target709G24" Content="Rec.709 Gamma 2.4 (BT.1886)" GroupName="Target"/>
                            <RadioButton x:Name="TargetP3D65" Content="DCI-P3 D65" GroupName="Target"/>
                            <RadioButton x:Name="Target2020SDR" Content="BT.2020 SDR (Gamma 2.4)" GroupName="Target"/>
                            <RadioButton x:Name="Target2020PQ" Content="BT.2020 PQ (HDR)" GroupName="Target"/>
                        </StackPanel>
                    </Border>

                    <!-- Calibration Preset -->
                    <TextBlock Text="Calibration Preset" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                    <Border Background="{StaticResource CardBackground}" CornerRadius="6" Padding="12" Margin="0,0,0,20">
                        <StackPanel>
                            <RadioButton x:Name="PresetQuick" GroupName="Preset">
                                <StackPanel>
                                    <TextBlock Text="Quick (125 patches)" FontWeight="Medium"/>
                                    <TextBlock Text="~8 minutes • Good accuracy" Foreground="{StaticResource TextDim}" FontSize="11"/>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton x:Name="PresetStandard" IsChecked="True" GroupName="Preset" Margin="0,8,0,0">
                                <StackPanel>
                                    <TextBlock Text="Standard (343 patches)" FontWeight="Medium"/>
                                    <TextBlock Text="~20 minutes • Very good accuracy" Foreground="{StaticResource TextDim}" FontSize="11"/>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton x:Name="PresetThorough" GroupName="Preset" Margin="0,8,0,0">
                                <StackPanel>
                                    <TextBlock Text="Thorough (729 patches)" FontWeight="Medium"/>
                                    <TextBlock Text="~45 minutes • Excellent accuracy" Foreground="{StaticResource TextDim}" FontSize="11"/>
                                </StackPanel>
                            </RadioButton>
                        </StackPanel>
                    </Border>

                    <!-- Colorimeter Status -->
                    <TextBlock Text="Colorimeter Status" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                    <Border Background="{StaticResource CardBackground}" CornerRadius="6" Padding="12" Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Ellipse x:Name="StatusIndicator" Width="12" Height="12" Fill="{StaticResource WarningBrush}"
                                     VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock x:Name="StatusText" Text="Checking..." FontWeight="Medium"/>
                                <TextBlock x:Name="ColorimeterModelText" Text="" Foreground="{StaticResource TextDim}" FontSize="11"/>
                            </StackPanel>
                            <Button Grid.Column="2" Content="Refresh" Background="#444" Padding="12,6"
                                    Click="Refresh_Click" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer Buttons -->
            <Border Grid.Row="2" Background="#252525" CornerRadius="0,0,8,8" Padding="24,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="1" Content="Cancel" Background="#444" Click="Cancel_Click" Margin="0,0,12,0"/>
                    <Button x:Name="StartButton" Grid.Column="2" Content="Start Calibration" Click="Start_Click" IsEnabled="False"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
