<Window x:Class="HDRGammaController.CalibrationSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Calibration Setup"
        Height="740" Width="600"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        Foreground="White"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#0078D4"/>
        <SolidColorBrush x:Key="CardBackground" Color="#2D2D2D"/>
        <SolidColorBrush x:Key="CardBorder" Color="#3F3F3F"/>
        <SolidColorBrush x:Key="TextDim" Color="#888888"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#22C55E"/>
        <SolidColorBrush x:Key="WarningBrush" Color="#F59E0B"/>
        <SolidColorBrush x:Key="ErrorBrush" Color="#EF4444"/>

        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark Mode ComboBox Style with proper popup support -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#3D3D3D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" Focusable="false"
                                          IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Border" Background="#3D3D3D"
                                                BorderBrush="{StaticResource CardBorder}" BorderThickness="1"
                                                CornerRadius="4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition/>
                                                    <ColumnDefinition Width="20"/>
                                                </Grid.ColumnDefinitions>
                                                <Path x:Name="Arrow" Grid.Column="1" Fill="White"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      Data="M 0 0 L 4 4 L 8 0 Z"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="#4D4D4D"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="10,8,25,8" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid x:Name="DropDown" SnapsToDevicePixels="True"
                                      MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder" Background="#2D2D2D"
                                            BorderBrush="{StaticResource CardBorder}" BorderThickness="1" CornerRadius="4"/>
                                    <ScrollViewer Margin="4,6,4,6" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark Mode ComboBoxItem Style -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Border" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}" CornerRadius="2">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#444444"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark Mode ScrollBar Style -->
        <Style x:Key="DarkScrollBar" TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Border Background="#252525" CornerRadius="5"/>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#555555" CornerRadius="5" Margin="2"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto"/>
                    <Setter Property="Height" Value="10"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Dark Mode ScrollViewer Style -->
        <Style TargetType="ScrollViewer">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <!-- Margin binding is what makes the ScrollViewer's declared Padding
                                 actually apply; without it content rides the window edge. -->
                            <ScrollContentPresenter Grid.Column="0" Grid.Row="0" Margin="{TemplateBinding Padding}"/>
                            <ScrollBar x:Name="PART_VerticalScrollBar" Grid.Column="1" Grid.Row="0"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                       Style="{StaticResource DarkScrollBar}"/>
                            <ScrollBar x:Name="PART_HorizontalScrollBar" Grid.Column="0" Grid.Row="1"
                                       Orientation="Horizontal"
                                       Value="{TemplateBinding HorizontalOffset}"
                                       Maximum="{TemplateBinding ScrollableWidth}"
                                       ViewportSize="{TemplateBinding ViewportWidth}"
                                       Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}"
                                       Style="{StaticResource DarkScrollBar}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>
    </Window.Resources>

    <Border Background="#1E1E1E" BorderBrush="#3F3F3F" BorderThickness="1" CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" Background="#252525" CornerRadius="8,8,0,0" MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid Margin="16,0">
                    <TextBlock Text="Display Calibration Setup" VerticalAlignment="Center" FontWeight="Medium" FontSize="14"/>
                    <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Center"
                            Background="Transparent" Foreground="#888" Padding="8,4"
                            Command="{Binding CancelCommand}"/>
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,16">
                <StackPanel>
                    <!-- Intro -->
                    <TextBlock Text="Configure your colorimeter calibration settings below."
                               Foreground="{StaticResource TextDim}" TextWrapping="Wrap" Margin="0,0,0,20"/>

                    <!-- Monitor Selection -->
                    <TextBlock Text="Select Monitor" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0" ItemsSource="{Binding Monitors}" SelectedItem="{Binding SelectedMonitor}"/>
                        <Button Grid.Column="1" Content="Identify"
                                Command="{Binding IdentifyCommand}" Margin="8,0,0,0" Padding="14,6"
                                ToolTip="Flash a number on the selected display"/>
                    </Grid>

                    <!-- Display Type Selection -->
                    <TextBlock Text="Display Type" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                    <Border Background="{StaticResource CardBackground}" CornerRadius="6" Padding="12" Margin="0,0,0,20">
                        <StackPanel>
                            <RadioButton GroupName="DisplayType" IsChecked="{Binding IsLcdLed}">
                                <StackPanel>
                                    <TextBlock Text="LCD (LED backlight)" FontWeight="Medium"/>
                                    <TextBlock Text="Most modern monitors and TVs"
                                               Foreground="{StaticResource TextDim}" FontSize="11"/>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton GroupName="DisplayType" IsChecked="{Binding IsOled}" Margin="0,8,0,0">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="OLED" FontWeight="Medium"/>
                                        <Border Background="{StaticResource SuccessBrush}" CornerRadius="2"
                                                Padding="5,1" Margin="8,0,0,0" VerticalAlignment="Center"
                                                Visibility="{Binding IsOledDetected, Converter={StaticResource BoolToVis}}"
                                                ToolTip="Identified by name, or by a wide gamut with a reported true-black HDR floor">
                                            <TextBlock Text="DETECTED" FontSize="9" FontWeight="SemiBold" Foreground="#1E1E1E"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="Self-emissive pixels, deep blacks"
                                               Foreground="{StaticResource TextDim}" FontSize="11"/>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton GroupName="DisplayType" IsChecked="{Binding IsLcdWideGamut}" Margin="0,8,0,0">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="LCD (Wide Gamut LED)" FontWeight="Medium"/>
                                        <Border Background="{StaticResource SuccessBrush}" CornerRadius="2"
                                                Padding="5,1" Margin="8,0,0,0" VerticalAlignment="Center"
                                                Visibility="{Binding IsWideGamutDetected, Converter={StaticResource BoolToVis}}"
                                                ToolTip="This panel's EDID primaries span well past sRGB and it reports an LCD-like black floor">
                                            <TextBlock Text="DETECTED" FontSize="9" FontWeight="SemiBold" Foreground="#1E1E1E"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="Professional monitors with extended color"
                                               Foreground="{StaticResource TextDim}" FontSize="11"/>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton GroupName="DisplayType" IsChecked="{Binding IsLcdCcfl}" Margin="0,8,0,0">
                                <StackPanel>
                                    <TextBlock Text="LCD (CCFL backlight)" FontWeight="Medium"/>
                                    <TextBlock Text="Older LCD monitors (pre-2012)"
                                               Foreground="{StaticResource TextDim}" FontSize="11"/>
                                </StackPanel>
                            </RadioButton>

                            <Border Visibility="{Binding IsOledHintVisible, Converter={StaticResource BoolToVis}}"
                                    Background="#2a2418" CornerRadius="4" Padding="10,8" Margin="0,10,0,0">
                                <TextBlock Foreground="#d9c184" FontSize="11" TextWrapping="Wrap"
                                           Text="OLED tip: calibrate with the panel WARM (30+ minutes of normal use). OLED white drifts a couple of dE while cold and through panel-compensation cycles; calibrating cold bakes the cold state into the profile."/>
                            </Border>

                            <TextBlock Text="Meter spectral correction" FontWeight="Medium" Margin="0,14,0,4"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox ItemsSource="{Binding Corrections}" SelectedItem="{Binding SelectedCorrection}">
                                    <ComboBox.ItemContainerStyle>
                                        <Style TargetType="ComboBoxItem" BasedOn="{StaticResource {x:Type ComboBoxItem}}">
                                            <Setter Property="ToolTip" Value="{Binding Path}"/>
                                        </Style>
                                    </ComboBox.ItemContainerStyle>
                                </ComboBox>
                                <Button Grid.Column="1" Content="Find online…"
                                        Margin="6,0,0,0" Padding="10,2" Click="FindCorrection_Click"/>
                                <Button Grid.Column="2" Content="Browse…"
                                        Margin="6,0,0,0" Padding="10,2" Click="BrowseCorrection_Click"/>
                            </Grid>
                            <TextBlock Foreground="{StaticResource TextDim}" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"
                                       Text="A correction file (.ccss/.ccmx) matched to this exact panel makes the colorimeter read it truthfully. Essential on QD-OLED, where generic corrections shift the white point green/magenta by several ΔE. Use Find online to get one from the DisplayCAL community database. Remembered per monitor."/>

                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                <Button x:Name="ManageProfilesButton" Content="Manage installed calibration profiles…"
                                        Padding="10,4" Background="#3D3D3D" Click="ManageProfiles_Click"/>
                                <Button x:Name="PastReportsButton" Content="Past reports…"
                                        Padding="10,4" Background="#3D3D3D" Margin="8,0,0,0" Click="PastReports_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Calibration Target -->
                    <TextBlock Text="Calibration Target" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                    <Border Background="{StaticResource CardBackground}" CornerRadius="6" Padding="12" Margin="0,0,0,20">
                        <StackPanel>
                            <ItemsControl ItemsSource="{Binding Targets}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <RadioButton GroupName="Target" Content="{Binding Label}"
                                                     IsChecked="{Binding IsSelected}"
                                                     IsEnabled="{Binding IsEnabled}"
                                                     ToolTip="{Binding DisabledReason}"
                                                     ToolTipService.ShowOnDisabled="True">
                                            <RadioButton.Style>
                                                <Style TargetType="RadioButton" BasedOn="{StaticResource {x:Type RadioButton}}">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsEnabled" Value="False">
                                                            <Setter Property="Opacity" Value="0.45"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </RadioButton.Style>
                                        </RadioButton>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <CheckBox Margin="0,12,0,0" Foreground="White"
                                      IsChecked="{Binding WhitePointOnly}"
                                      Content="White point correction only (skip gamut re-mapping)"/>
                            <TextBlock Foreground="{StaticResource TextDim}" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"
                                       Text="Corrects white point and tone but leaves the panel's color gamut untouched. Recommended when the native gamut already measures close to the target, or on OLEDs in HDR, where the panel's own processing makes full gamut correction overshoot. Auto-suggested for OLED."/>
                        </StackPanel>
                    </Border>

                    <!-- Calibration Preset -->
                    <TextBlock Text="Calibration Preset" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                    <Border Background="{StaticResource CardBackground}" CornerRadius="6" Padding="12" Margin="0,0,0,20">
                        <StackPanel>
                            <RadioButton GroupName="Preset" IsChecked="{Binding IsPresetQuick}">
                                <StackPanel>
                                    <TextBlock Text="Quick (125 patches)" FontWeight="Medium"/>
                                    <TextBlock Text="~8 minutes • Good accuracy" Foreground="{StaticResource TextDim}" FontSize="11"/>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton GroupName="Preset" IsChecked="{Binding IsPresetStandard}" Margin="0,8,0,0">
                                <StackPanel>
                                    <TextBlock Text="Standard (343 patches)" FontWeight="Medium"/>
                                    <TextBlock Text="~20 minutes • Very good accuracy" Foreground="{StaticResource TextDim}" FontSize="11"/>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton GroupName="Preset" IsChecked="{Binding IsPresetThorough}" Margin="0,8,0,0">
                                <StackPanel>
                                    <TextBlock Text="Thorough (729 patches)" FontWeight="Medium"/>
                                    <TextBlock Text="~45 minutes • Excellent accuracy" Foreground="{StaticResource TextDim}" FontSize="11"/>
                                </StackPanel>
                            </RadioButton>
                        </StackPanel>
                    </Border>

                    <!-- Colorimeter Status -->
                    <TextBlock Text="Colorimeter Status" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                    <Border Background="{StaticResource CardBackground}" CornerRadius="6" Padding="12" Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Ellipse Width="12" Height="12" Fill="{Binding StatusBrush}"
                                     VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding StatusText}" FontWeight="Medium"/>
                                <TextBlock Text="{Binding StatusDetailText}" Foreground="{StaticResource TextDim}" FontSize="11"/>
                            </StackPanel>
                            <Button Grid.Column="2" Content="Refresh" Background="#444" Padding="12,6"
                                    Command="{Binding RefreshColorimeterCommand}" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer Buttons -->
            <Border Grid.Row="2" Background="#252525" CornerRadius="0,0,8,8" Padding="24,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="1" Content="Cancel" Background="#444" Command="{Binding CancelCommand}" Margin="0,0,12,0"/>
                    <Button Grid.Column="2" Content="Start Calibration" Command="{Binding StartCommand}" IsEnabled="{Binding CanStart}"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>

