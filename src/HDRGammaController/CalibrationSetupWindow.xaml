<Window x:Class="HDRGammaController.CalibrationSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:HDRGammaController"
        Title="Calibration Setup"
        Height="740" Width="600"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        Foreground="{DynamicResource ThemeText}"
        FontFamily="{DynamicResource BodyFont}"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Gloam;component/Themes/Brutalist.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
            <SolidColorBrush x:Key="SuccessBrush" Color="#22C55E"/>
            <SolidColorBrush x:Key="WarningBrush" Color="#F59E0B"/>
            <SolidColorBrush x:Key="ErrorBrush" Color="#EF4444"/>
        </ResourceDictionary>
    </Window.Resources>

    <Border Background="{DynamicResource ThemeBg}" BorderBrush="{DynamicResource ThemeWindowFrame}" BorderThickness="2">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" Background="{DynamicResource ThemeSurface}"
                    BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="0,0,0,3"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid Margin="16,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <local:BrandMark Width="20" Height="20" Margin="0,0,10,0" VerticalAlignment="Center" GapBrush="{DynamicResource ThemeSurface}"/>
                        <TextBlock Text="CALIBRATION SETUP" FontFamily="{DynamicResource DisplayFont}"
                                   FontWeight="Bold" FontSize="13" Foreground="{DynamicResource ThemeText}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button x:Name="ThemeToggleButton" Content="&#x25D0;" Width="30" Height="30" FontSize="15"
                                Style="{StaticResource BrutIconButton}" ToolTip="Toggle light / dark" Click="ThemeToggle_Click"/>
                        <Button Content="&#x2715;" Width="30" Height="30" FontSize="13"
                                Style="{StaticResource BrutIconButton}" Command="{Binding CancelCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,16">
                <StackPanel>
                    <!-- Intro -->
                    <TextBlock Text="Configure your colorimeter calibration settings below."
                               Foreground="{StaticResource TextDim}" TextWrapping="Wrap" Margin="0,0,0,20"/>

                    <!-- Monitor Selection -->
                    <TextBlock Text="Select Monitor" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0" ItemsSource="{Binding Monitors}" SelectedItem="{Binding SelectedMonitor}"/>
                        <Button Grid.Column="1" Content="Identify"
                                Command="{Binding IdentifyCommand}" Margin="8,0,0,0" Padding="14,6"
                                ToolTip="Flash a number on the selected display"/>
                    </Grid>

                    <!-- Display Type Selection -->
                    <TextBlock Text="Display Type" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                    <Border Background="{StaticResource CardBackground}" BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="2" Padding="12" Margin="0,0,0,20">
                        <StackPanel>
                            <RadioButton GroupName="DisplayType" IsChecked="{Binding IsLcdLed}">
                                <StackPanel>
                                    <TextBlock Text="LCD (LED backlight)" FontWeight="Medium"/>
                                    <TextBlock Text="Most modern monitors and TVs"
                                               Foreground="{StaticResource TextDim}" FontSize="11"/>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton GroupName="DisplayType" IsChecked="{Binding IsOled}" Margin="0,8,0,0">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="OLED" FontWeight="Medium"/>
                                        <Border Background="{StaticResource SuccessBrush}" Padding="5,1" Margin="8,0,0,0" VerticalAlignment="Center"
                                                Visibility="{Binding IsOledDetected, Converter={StaticResource BoolToVis}}"
                                                ToolTip="Identified by name, or by a wide gamut with a reported true-black HDR floor">
                                            <TextBlock Text="DETECTED" FontSize="9" FontWeight="SemiBold" Foreground="#1E1E1E"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="Self-emissive pixels, deep blacks"
                                               Foreground="{StaticResource TextDim}" FontSize="11"/>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton GroupName="DisplayType" IsChecked="{Binding IsLcdWideGamut}" Margin="0,8,0,0">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="LCD (Wide Gamut LED)" FontWeight="Medium"/>
                                        <Border Background="{StaticResource SuccessBrush}" Padding="5,1" Margin="8,0,0,0" VerticalAlignment="Center"
                                                Visibility="{Binding IsWideGamutDetected, Converter={StaticResource BoolToVis}}"
                                                ToolTip="This panel's EDID primaries span well past sRGB and it reports an LCD-like black floor">
                                            <TextBlock Text="DETECTED" FontSize="9" FontWeight="SemiBold" Foreground="#1E1E1E"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="Professional monitors with extended color"
                                               Foreground="{StaticResource TextDim}" FontSize="11"/>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton GroupName="DisplayType" IsChecked="{Binding IsLcdCcfl}" Margin="0,8,0,0">
                                <StackPanel>
                                    <TextBlock Text="LCD (CCFL backlight)" FontWeight="Medium"/>
                                    <TextBlock Text="Older LCD monitors (pre-2012)"
                                               Foreground="{StaticResource TextDim}" FontSize="11"/>
                                </StackPanel>
                            </RadioButton>

                            <Border Visibility="{Binding IsOledHintVisible, Converter={StaticResource BoolToVis}}"
                                    Background="Transparent" BorderBrush="{StaticResource WarningBrush}" BorderThickness="2" Padding="10,8" Margin="0,10,0,0">
                                <TextBlock Foreground="{StaticResource WarningBrush}" FontSize="11" TextWrapping="Wrap"
                                           Text="OLED tip: calibrate with the panel WARM (30+ minutes of normal use). OLED white drifts a couple of dE while cold and through panel-compensation cycles; calibrating cold bakes the cold state into the profile."/>
                            </Border>

                            <TextBlock Text="Meter spectral correction" FontWeight="Medium" Margin="0,14,0,4"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox ItemsSource="{Binding Corrections}" SelectedItem="{Binding SelectedCorrection}">
                                    <ComboBox.ItemContainerStyle>
                                        <Style TargetType="ComboBoxItem" BasedOn="{StaticResource {x:Type ComboBoxItem}}">
                                            <Setter Property="ToolTip" Value="{Binding Path}"/>
                                        </Style>
                                    </ComboBox.ItemContainerStyle>
                                </ComboBox>
                                <Button Grid.Column="1" Content="Find online…"
                                        Margin="6,0,0,0" Padding="10,2" Click="FindCorrection_Click"/>
                                <Button Grid.Column="2" Content="Browse…"
                                        Margin="6,0,0,0" Padding="10,2" Click="BrowseCorrection_Click"/>
                            </Grid>
                            <TextBlock Foreground="{StaticResource TextDim}" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"
                                       Text="A correction file (.ccss/.ccmx) matched to this exact panel makes the colorimeter read it truthfully. Essential on QD-OLED, where generic corrections shift the white point green/magenta by several ΔE. Use Find online to get one from the DisplayCAL community database. Remembered per monitor."/>

                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                <Button x:Name="ManageProfilesButton" Content="Manage installed calibration profiles…"
                                        Padding="10,4" Click="ManageProfiles_Click"/>
                                <Button x:Name="PastReportsButton" Content="Past reports…"
                                        Padding="10,4" Margin="8,0,0,0" Click="PastReports_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Calibration Target -->
                    <TextBlock Text="Calibration Target" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                    <Border Background="{StaticResource CardBackground}" BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="2" Padding="12" Margin="0,0,0,20">
                        <StackPanel>
                            <ItemsControl ItemsSource="{Binding Targets}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <RadioButton GroupName="Target" Content="{Binding Label}"
                                                     IsChecked="{Binding IsSelected}"
                                                     IsEnabled="{Binding IsEnabled}"
                                                     ToolTip="{Binding DisabledReason}"
                                                     ToolTipService.ShowOnDisabled="True">
                                            <RadioButton.Style>
                                                <Style TargetType="RadioButton" BasedOn="{StaticResource {x:Type RadioButton}}">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsEnabled" Value="False">
                                                            <Setter Property="Opacity" Value="0.45"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </RadioButton.Style>
                                        </RadioButton>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <CheckBox Margin="0,12,0,0" Foreground="{DynamicResource ThemeText}"
                                      IsChecked="{Binding WhitePointOnly}"
                                      Content="White point correction only (skip gamut re-mapping)"/>
                            <TextBlock Foreground="{StaticResource TextDim}" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"
                                       Text="Corrects white point and tone but leaves the panel's color gamut untouched. Recommended when the native gamut already measures close to the target, or on OLEDs in HDR, where the panel's own processing makes full gamut correction overshoot. Auto-suggested for OLED."/>
                        </StackPanel>
                    </Border>

                    <!-- Calibration Preset -->
                    <TextBlock Text="Calibration Preset" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                    <Border Background="{StaticResource CardBackground}" BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="2" Padding="12" Margin="0,0,0,20">
                        <StackPanel>
                            <RadioButton GroupName="Preset" IsChecked="{Binding IsPresetQuick}">
                                <StackPanel>
                                    <TextBlock Text="Quick (125 patches)" FontWeight="Medium"/>
                                    <TextBlock Text="~8 minutes • Good accuracy" Foreground="{StaticResource TextDim}" FontSize="11"/>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton GroupName="Preset" IsChecked="{Binding IsPresetStandard}" Margin="0,8,0,0">
                                <StackPanel>
                                    <TextBlock Text="Standard (343 patches)" FontWeight="Medium"/>
                                    <TextBlock Text="~20 minutes • Very good accuracy" Foreground="{StaticResource TextDim}" FontSize="11"/>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton GroupName="Preset" IsChecked="{Binding IsPresetThorough}" Margin="0,8,0,0">
                                <StackPanel>
                                    <TextBlock Text="Thorough (729 patches)" FontWeight="Medium"/>
                                    <TextBlock Text="~45 minutes • Excellent accuracy" Foreground="{StaticResource TextDim}" FontSize="11"/>
                                </StackPanel>
                            </RadioButton>
                        </StackPanel>
                    </Border>

                    <!-- Preflight -->
                    <TextBlock Text="Preflight" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"
                               Visibility="{Binding HasPreflightItems, Converter={StaticResource BoolToVis}}"/>
                    <Border Background="{StaticResource CardBackground}" BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="2" Padding="12" Margin="0,0,0,20"
                            Visibility="{Binding HasPreflightItems, Converter={StaticResource BoolToVis}}">
                        <ItemsControl ItemsSource="{Binding PreflightItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Background="{Binding Brush}" Padding="5,1" Margin="0,1,8,0" VerticalAlignment="Top">
                                            <TextBlock Text="{Binding Severity}" FontSize="9" FontWeight="SemiBold" Foreground="#1E1E1E"/>
                                        </Border>
                                        <TextBlock Grid.Column="1" Text="{Binding Message}" TextWrapping="Wrap"
                                                   Foreground="{DynamicResource ThemeText}" FontSize="11"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>

                    <!-- Colorimeter Status -->
                    <TextBlock Text="Colorimeter Status" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                    <Border Background="{StaticResource CardBackground}" BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="2" Padding="12" Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Ellipse Width="12" Height="12" Fill="{Binding StatusBrush}"
                                     VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding StatusText}" FontWeight="Medium"/>
                                <TextBlock Text="{Binding StatusDetailText}" Foreground="{StaticResource TextDim}" FontSize="11"/>
                            </StackPanel>
                            <Button Grid.Column="2" Content="Refresh" Padding="12,6"
                                    Command="{Binding RefreshColorimeterCommand}" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer Buttons -->
            <Border Grid.Row="2" Background="{DynamicResource ThemeSurface}"
                    BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="0,3,0,0" Padding="24,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="1" Content="Cancel" Command="{Binding CancelCommand}" Margin="0,0,12,0"/>
                    <Button Grid.Column="2" Content="Start Calibration" Style="{StaticResource BrutBtnPrimary}" Command="{Binding StartCommand}" IsEnabled="{Binding CanStart}"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
