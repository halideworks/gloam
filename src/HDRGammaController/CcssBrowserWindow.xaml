<Window x:Class="HDRGammaController.CcssBrowserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Find Meter Correction"
        Width="760" Height="560" MinWidth="760" MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ThemeBg}"
        Foreground="{DynamicResource ThemeText}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/DarkControls.xaml"/>
                <ResourceDictionary Source="Themes/Brutalist.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <DataTemplate x:Key="CorrectionTypeChip">
                <Border BorderThickness="1" Padding="6,1"
                        HorizontalAlignment="Left" VerticalAlignment="Center">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="BorderBrush" Value="{DynamicResource ThemeAccent}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Type}" Value="ccmx">
                                    <Setter Property="BorderBrush" Value="{DynamicResource ThemeAmber}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding Type}" FontSize="11" FontWeight="Bold"
                               Foreground="{DynamicResource ThemeText}"/>
                </Border>
            </DataTemplate>
        </ResourceDictionary>
    </Window.Resources>

    <Grid x:Name="BodyRoot" Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="_query"
                     FontSize="13" Padding="8,6" BorderThickness="1"
                     VerticalContentAlignment="Center"
                     Background="{DynamicResource ThemeSurface}"
                     Foreground="{DynamicResource ThemeText}"
                     BorderBrush="{DynamicResource ThemeBorder}"
                     CaretBrush="{DynamicResource ThemeText}"
                     KeyDown="Query_KeyDown"/>
            <Button x:Name="_searchButton" Grid.Column="1" Content="Search"
                    Margin="8,0,0,0" Style="{DynamicResource BrutBtnPrimary}"
                    Click="Search_Click"/>
        </Grid>

        <ListView x:Name="_list" Grid.Row="1" Margin="0,10" BorderThickness="1"
                  Background="{DynamicResource ThemeSurface}"
                  Foreground="{DynamicResource ThemeText}"
                  BorderBrush="{DynamicResource ThemeBorder}"
                  SelectionChanged="Correction_SelectionChanged"
                  MouseDoubleClick="Correction_MouseDoubleClick">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Source" Width="70" DisplayMemberBinding="{Binding Source}"/>
                    <GridViewColumn Header="Display" Width="250" DisplayMemberBinding="{Binding Display}"/>
                    <GridViewColumn Header="Type" Width="64" CellTemplate="{StaticResource CorrectionTypeChip}"/>
                    <GridViewColumn Header="Instrument" Width="130" DisplayMemberBinding="{Binding Instrument}"/>
                    <GridViewColumn Header="Measured with" Width="150" DisplayMemberBinding="{Binding Reference}"/>
                    <GridViewColumn Header="Created" Width="120" DisplayMemberBinding="{Binding Created}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel VerticalAlignment="Bottom">
                <TextBlock x:Name="_status" FontSize="12" TextWrapping="Wrap"
                           Foreground="{DynamicResource ThemeTextDim}"/>
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <Button x:Name="_createButton" Content="From spectrometer…"
                            Style="{DynamicResource BrutBtnSecondary}" Click="CreateSpectral_Click"/>
                    <Button x:Name="_createMatrixButton" Content="Correction matrix…" Margin="8,0,0,0"
                            Style="{DynamicResource BrutBtnSecondary}" Click="CreateMatrix_Click"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                    <Button x:Name="_deleteButton" Content="Delete" IsEnabled="False"
                            Style="{DynamicResource BrutBtnSecondary}" Click="Delete_Click"/>
                    <Button x:Name="_dedupeButton" Content="Remove duplicates" Margin="8,0,0,0"
                            Style="{DynamicResource BrutBtnSecondary}" Click="Dedupe_Click"/>
                </StackPanel>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal"
                        VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="12,0,0,0">
                <Button x:Name="_downloadButton" Content="Download &amp; Use" IsEnabled="False"
                        Margin="0,0,8,0" Style="{DynamicResource BrutBtnPrimary}"
                        Click="Download_Click"/>
                <Button x:Name="_closeButton" Content="Cancel"
                        Style="{DynamicResource BrutBtnSecondary}" Click="Close_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
