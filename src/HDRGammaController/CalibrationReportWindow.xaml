<Window x:Class="HDRGammaController.CalibrationReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Calibration Report"
        Width="900" Height="700"
        MinWidth="700" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Background="#1e1e1e"
        Foreground="#e0e0e0">

    <Window.Resources>
        <!-- Styles -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#0891b2"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="MetricLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#a0a0a0"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>

        <Style x:Key="MetricValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#e0e0e0"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>

        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="#2d2d2d"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#0891b2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#06b6d4"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#3d3d3d"/>
            <Setter Property="Foreground" Value="#e0e0e0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4d4d4d"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GradeText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="44"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Dark scrollbar matching the report theme (replaces the default light one). -->
        <Style x:Key="DarkScrollThumb" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="#4d4d4d" CornerRadius="4" Margin="2,0"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#5d5d5d"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="#1e1e1e">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" Focusable="False"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource DarkScrollThumb}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" Focusable="False"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#252525" Padding="20,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Calibration Report" FontSize="22" FontWeight="SemiBold" Foreground="#e0e0e0"/>
                    <TextBlock x:Name="MonitorNameText" Text="Monitor Name" FontSize="13" Foreground="#a0a0a0" Margin="0,4,0,0"/>
                    <TextBlock x:Name="CalibrationDateText" Text="Calibrated: Today" FontSize="12" Foreground="#707070" Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Grade Display (the letter in a colored disc is self-evidently a grade) -->
                <Border Grid.Column="1" Width="100" Height="100" CornerRadius="50" x:Name="GradeBorder" Background="#164e63">
                    <TextBlock x:Name="GradeText" Style="{StaticResource GradeText}" Foreground="#22d3ee"/>
                </Border>
            </Grid>
        </Border>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20">
            <StackPanel>
                <!-- Summary Section -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="Measured Display Deviation" Style="{StaticResource SectionHeader}"/>
                        <TextBlock Text="How far your display reads from the target before correction. The generated LUT is built to cancel this — higher numbers mean more to correct, not a failed calibration."
                                   FontSize="12" Foreground="#909090" TextWrapping="Wrap" Margin="0,-4,0,12"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Average Delta E -->
                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                <TextBlock Text="Average Delta E" Style="{StaticResource MetricLabel}" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="AvgDeltaEText" Text="0.00" Style="{StaticResource MetricValue}" FontSize="28" HorizontalAlignment="Center"/>
                            </StackPanel>

                            <!-- Max Delta E -->
                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                <TextBlock Text="Max Delta E" Style="{StaticResource MetricLabel}" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="MaxDeltaEText" Text="0.00" Style="{StaticResource MetricValue}" FontSize="28" HorizontalAlignment="Center"/>
                            </StackPanel>

                            <!-- Grayscale Delta E -->
                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                <TextBlock Text="Grayscale Avg" Style="{StaticResource MetricLabel}" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="GrayscaleDeltaEText" Text="0.00" Style="{StaticResource MetricValue}" FontSize="28" HorizontalAlignment="Center"/>
                            </StackPanel>

                            <!-- Primary Delta E -->
                            <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                                <TextBlock Text="Primary Avg" Style="{StaticResource MetricLabel}" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="PrimaryDeltaEText" Text="0.00" Style="{StaticResource MetricValue}" FontSize="28" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock x:Name="SummaryText"
                                   Text="Calibration completed successfully."
                                   FontSize="13"
                                   Foreground="#a0a0a0"
                                   TextWrapping="Wrap"
                                   Margin="0,16,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Display Characteristics -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="Display Characteristics" Style="{StaticResource SectionHeader}"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Peak Luminance -->
                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,12">
                                <TextBlock Text="Peak Luminance" Style="{StaticResource MetricLabel}"/>
                                <TextBlock x:Name="PeakLuminanceText" Text="-- cd/m2" Style="{StaticResource MetricValue}"/>
                            </StackPanel>

                            <!-- Black Level -->
                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,12">
                                <TextBlock Text="Black Level" Style="{StaticResource MetricLabel}"/>
                                <TextBlock x:Name="BlackLevelText" Text="-- cd/m2" Style="{StaticResource MetricValue}"/>
                            </StackPanel>

                            <!-- Contrast Ratio -->
                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,12">
                                <TextBlock Text="Contrast Ratio" Style="{StaticResource MetricLabel}"/>
                                <TextBlock x:Name="ContrastRatioText" Text="--:1" Style="{StaticResource MetricValue}"/>
                            </StackPanel>

                            <!-- Measured Gamma -->
                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,12">
                                <TextBlock Text="Measured Gamma" Style="{StaticResource MetricLabel}"/>
                                <TextBlock x:Name="MeasuredGammaText" Text="--" Style="{StaticResource MetricValue}"/>
                            </StackPanel>

                            <!-- White Point CCT -->
                            <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,0,12">
                                <TextBlock Text="White Point CCT" Style="{StaticResource MetricLabel}"/>
                                <TextBlock x:Name="WhitePointCctText" Text="-- K" Style="{StaticResource MetricValue}"/>
                            </StackPanel>

                            <!-- White Point Duv -->
                            <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,0,12">
                                <TextBlock Text="White Point Duv" Style="{StaticResource MetricLabel}"/>
                                <TextBlock x:Name="WhitePointDuvText" Text="--" Style="{StaticResource MetricValue}"/>
                            </StackPanel>

                            <!-- Gamut Coverage -->
                            <StackPanel Grid.Row="3" Grid.Column="0">
                                <TextBlock Text="sRGB Coverage" Style="{StaticResource MetricLabel}"/>
                                <TextBlock x:Name="SrgbCoverageText" Text="--%" Style="{StaticResource MetricValue}"/>
                            </StackPanel>

                            <!-- Target -->
                            <StackPanel Grid.Row="3" Grid.Column="1">
                                <TextBlock Text="Calibration Target" Style="{StaticResource MetricLabel}"/>
                                <TextBlock x:Name="TargetText" Text="--" Style="{StaticResource MetricValue}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Primaries Comparison -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="Color Primaries" Style="{StaticResource SectionHeader}"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Headers -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="" Style="{StaticResource MetricLabel}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="Measured" Style="{StaticResource MetricLabel}"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Target" Style="{StaticResource MetricLabel}"/>
                            <TextBlock Grid.Row="0" Grid.Column="3" Text="Error" Style="{StaticResource MetricLabel}"/>

                            <!-- Red -->
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Red" Foreground="#ef4444" Style="{StaticResource MetricValue}"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="RedMeasuredText" Text="(0.640, 0.330)" Style="{StaticResource MetricValue}"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" x:Name="RedTargetText" Text="(0.640, 0.330)" Style="{StaticResource MetricValue}"/>
                            <TextBlock Grid.Row="1" Grid.Column="3" x:Name="RedErrorText" Text="0.000" Style="{StaticResource MetricValue}"/>

                            <!-- Green -->
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Green" Foreground="#22c55e" Style="{StaticResource MetricValue}"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="GreenMeasuredText" Text="(0.300, 0.600)" Style="{StaticResource MetricValue}"/>
                            <TextBlock Grid.Row="2" Grid.Column="2" x:Name="GreenTargetText" Text="(0.300, 0.600)" Style="{StaticResource MetricValue}"/>
                            <TextBlock Grid.Row="2" Grid.Column="3" x:Name="GreenErrorText" Text="0.000" Style="{StaticResource MetricValue}"/>

                            <!-- Blue -->
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Blue" Foreground="#3b82f6" Style="{StaticResource MetricValue}"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="BlueMeasuredText" Text="(0.150, 0.060)" Style="{StaticResource MetricValue}"/>
                            <TextBlock Grid.Row="3" Grid.Column="2" x:Name="BlueTargetText" Text="(0.150, 0.060)" Style="{StaticResource MetricValue}"/>
                            <TextBlock Grid.Row="3" Grid.Column="3" x:Name="BlueErrorText" Text="0.000" Style="{StaticResource MetricValue}"/>

                            <!-- White -->
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="White" Style="{StaticResource MetricValue}"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" x:Name="WhiteMeasuredText" Text="(0.313, 0.329)" Style="{StaticResource MetricValue}"/>
                            <TextBlock Grid.Row="4" Grid.Column="2" x:Name="WhiteTargetText" Text="(0.313, 0.329)" Style="{StaticResource MetricValue}"/>
                            <TextBlock Grid.Row="4" Grid.Column="3" x:Name="WhiteErrorText" Text="0.000" Style="{StaticResource MetricValue}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Calibration Info -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="Calibration Details" Style="{StaticResource SectionHeader}"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,12">
                                <TextBlock Text="Patches Measured" Style="{StaticResource MetricLabel}"/>
                                <TextBlock x:Name="PatchCountText" Text="--" Style="{StaticResource MetricValue}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,12">
                                <TextBlock Text="Measurement Time" Style="{StaticResource MetricLabel}"/>
                                <TextBlock x:Name="MeasurementTimeText" Text="--" Style="{StaticResource MetricValue}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,12">
                                <TextBlock Text="Colorimeter" Style="{StaticResource MetricLabel}"/>
                                <TextBlock x:Name="ColorimeterText" Text="--" Style="{StaticResource MetricValue}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,12">
                                <TextBlock Text="LUT Size" Style="{StaticResource MetricLabel}"/>
                                <TextBlock x:Name="LutSizeText" Text="--" Style="{StaticResource MetricValue}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2">
                                <TextBlock Text="Profile Location" Style="{StaticResource MetricLabel}"/>
                                <TextBlock x:Name="ProfilePathText" Text="--" Style="{StaticResource MetricValue}" TextWrapping="Wrap" FontSize="11"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Recommendations -->
                <Border Style="{StaticResource CardBorder}" x:Name="RecommendationsPanel">
                    <StackPanel>
                        <TextBlock Text="Recommendations" Style="{StaticResource SectionHeader}"/>
                        <ItemsControl x:Name="RecommendationsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,4">
                                        <TextBlock Text="*" Foreground="#0891b2" FontWeight="Bold" Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding}" TextWrapping="Wrap" Foreground="#a0a0a0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer with Actions -->
        <Border Grid.Row="2" Background="#252525" Padding="20,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" x:Name="StatusText"
                           Text="Profile is active and applied."
                           Foreground="#22c55e"
                           VerticalAlignment="Center"
                           FontSize="13"/>

                <Button Grid.Column="1"
                        x:Name="ExportButton"
                        Content="Export LUT"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,0,10,0"
                        Click="ExportButton_Click"/>

                <Button Grid.Column="2"
                        x:Name="ApplyButton"
                        Content="Apply Profile"
                        Style="{StaticResource ActionButton}"
                        Margin="0,0,10,0"
                        Click="ApplyButton_Click"/>

                <Button Grid.Column="3"
                        x:Name="CloseButton"
                        Content="Close"
                        Style="{StaticResource SecondaryButton}"
                        Click="CloseButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
