<Window x:Class="HDRGammaController.CalibrationReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:HDRGammaController"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Calibration Report"
        Width="960" Height="860"
        MinWidth="820" MinHeight="560"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        Foreground="{DynamicResource ThemeText}"
        FontFamily="{DynamicResource BodyFont}"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Gloam;component/Themes/Brutalist.xaml"/>
            </ResourceDictionary.MergedDictionaries>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Dark report surface with app-aligned chrome and accents. -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{DynamicResource DisplayFont}"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeAccent}"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="MetricLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextDim}"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>

        <Style x:Key="MetricValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeText}"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>

        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ThemeSurface}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="GradeText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="32"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <!-- Optical centering: bold capitals sit slightly below the geometric middle of
                 the line box, so nudge up a touch inside the circle. -->
            <Setter Property="Margin" Value="0,-3,0,0"/>
        </Style>

        </ResourceDictionary>
    </Window.Resources>

    <!-- Custom chrome: draggable header (no OS title bar) -->
    <Border Background="{DynamicResource ThemeBg}" BorderBrush="{DynamicResource ThemeWindowFrame}" BorderThickness="1">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header (drag bar) -->
        <Border Grid.Row="0" Background="{DynamicResource ThemeSurface}" BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="0,0,0,1" Padding="20,16"
                MouseLeftButtonDown="Header_MouseDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <local:BrandMark Width="20" Height="20" Margin="0,0,9,0" VerticalAlignment="Center" GapBrush="{DynamicResource ThemeSurface}"/>
                        <TextBlock Text="Calibration report" FontFamily="{DynamicResource DisplayFont}"
                                   FontWeight="ExtraBold" FontSize="20" Foreground="{DynamicResource ThemeText}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="{Binding MonitorNameText}" FontSize="13" Foreground="{DynamicResource ThemeTextDim}" Margin="0,2,0,0"/>
                    <TextBlock Text="{Binding CalibrationDateText}" FontSize="12" Foreground="{DynamicResource ThemeTextDim}" Opacity="0.75" Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Grade Display (the letter in a colored disc is self-evidently a grade) -->
                <StackPanel Grid.Column="1" Margin="0,0,8,0">
                    <Border Width="84" Height="84" CornerRadius="42" Background="{Binding GradeBackground}">
                        <TextBlock Text="{Binding GradeText}" Style="{StaticResource GradeText}" Foreground="{Binding GradeBrush}"/>
                    </Border>
                    <TextBlock Text="{Binding GradeScopeText}" FontSize="10" Foreground="{DynamicResource ThemeTextDim}"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Window close (custom chrome) -->
                <TextBlock Grid.Column="1" Text="&#x2715;" FontSize="15" Cursor="Hand"
                           HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-6,-6,0"
                           MouseLeftButtonDown="CloseGlyph_Click">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{DynamicResource ThemeTextDim}"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource ThemeAccent}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </Border>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20">
            <!-- Export Report does NOT print this dark UI: ReportPrintBuilder rebuilds the
                 report as a light, printer-friendly FlowDocument from the same view model. -->
            <StackPanel x:Name="ReportContent">
                <!-- Summary Section: before/after accuracy table -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="Accuracy (ΔE2000)" Style="{StaticResource SectionHeader}"/>
                        <TextBlock Text="Native = the uncorrected panel, measured during calibration. After = re-measured automatically through the applied profile (gamma preference and night mode are suspended during the sweep)."
                                   FontSize="12" Foreground="{DynamicResource ThemeTextDim}" TextWrapping="Wrap" Margin="0,-4,0,12"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Column headers -->
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="Average" Style="{StaticResource MetricLabel}" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Max" Style="{StaticResource MetricLabel}" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Row="0" Grid.Column="3" Text="Grayscale" Style="{StaticResource MetricLabel}" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Row="0" Grid.Column="4" Text="Primaries" Style="{StaticResource MetricLabel}" HorizontalAlignment="Center"/>

                            <!-- Before: native panel -->
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Native (before)" Style="{StaticResource MetricLabel}" FontSize="13" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding AvgDeltaEText}" Foreground="{Binding AvgDeltaEBrush}" Style="{StaticResource MetricValue}" FontSize="22" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding MaxDeltaEText}" Foreground="{Binding MaxDeltaEBrush}" Style="{StaticResource MetricValue}" FontSize="22" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding GrayscaleDeltaEText}" Foreground="{Binding GrayscaleDeltaEBrush}" Style="{StaticResource MetricValue}" FontSize="22" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Row="1" Grid.Column="4" Text="{Binding PrimaryDeltaEText}" Foreground="{Binding PrimaryDeltaEBrush}" Style="{StaticResource MetricValue}" FontSize="22" HorizontalAlignment="Center"/>

                            <!-- After: re-measured through the applied correction -->
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Calibrated (after)" Style="{StaticResource MetricLabel}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding AfterAvgText}" Foreground="{Binding AfterAvgBrush}" Style="{StaticResource MetricValue}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding AfterMaxText}" Foreground="{Binding AfterMaxBrush}" Style="{StaticResource MetricValue}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Row="2" Grid.Column="3" Text="{Binding AfterGrayscaleText}" Foreground="{Binding AfterGrayscaleBrush}" Style="{StaticResource MetricValue}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Row="2" Grid.Column="4" Text="{Binding AfterPrimaryText}" Foreground="{Binding AfterPrimaryBrush}" Style="{StaticResource MetricValue}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </Grid>

                        <!-- Verify detail: grayscale tone/color decomposition + dE ITP -->
                        <TextBlock Text="{Binding VerifyDetailText}"
                                   Visibility="{Binding IsVerifyDetailVisible, Converter={StaticResource BoolToVis}}"
                                   FontSize="12" Foreground="#a0a0a0" TextWrapping="Wrap" Margin="0,10,0,0"/>

                        <!-- Closed-loop grey-ramp refinement note (a different, narrower metric than
                             the table: 1D grey-axis tracking only, measured during calibration) -->
                        <TextBlock Text="{Binding BeforeAfterNoteText}"
                                   Visibility="{Binding IsBeforeAfterNoteVisible, Converter={StaticResource BoolToVis}}"
                                   FontSize="12" Foreground="#909090" TextWrapping="Wrap" Margin="0,10,0,0"/>

                        <TextBlock Text="{Binding SummaryText}"
                                   FontSize="13"
                                   Foreground="#a0a0a0"
                                   TextWrapping="Wrap"
                                   Margin="0,16,0,0"/>

                        <Border Visibility="{Binding IsPerceptualNoteVisible, Converter={StaticResource BoolToVis}}"
                                Background="#22303a" CornerRadius="0" Padding="12,10" Margin="0,12,0,0">
                            <TextBlock FontSize="12" Foreground="#a8c5d8" TextWrapping="Wrap"
                                       Text="Final step: trust your eyes. Instruments and eyes weigh light spectra differently, so two display technologies can measure identical yet look slightly different side by side (observer metamerism). If this display does not quite match your reference, nudge the Tint/Temperature trims in the monitor dashboard while comparing a gray image. Small trims are a normal part of professional workflows; they ride on top of this profile and never affect the measurements above."/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Display Characteristics -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="Display Characteristics" Style="{StaticResource SectionHeader}"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Peak Luminance -->
                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,12">
                                <TextBlock Text="Peak Luminance" Style="{StaticResource MetricLabel}"/>
                                <TextBlock Text="{Binding PeakLuminanceText}" Style="{StaticResource MetricValue}"/>
                            </StackPanel>

                            <!-- Black Level -->
                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,12">
                                <TextBlock Text="Black Level" Style="{StaticResource MetricLabel}"/>
                                <TextBlock Text="{Binding BlackLevelText}" Style="{StaticResource MetricValue}"/>
                            </StackPanel>

                            <!-- Contrast Ratio -->
                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,12">
                                <TextBlock Text="Contrast Ratio" Style="{StaticResource MetricLabel}"/>
                                <TextBlock Text="{Binding ContrastRatioText}" Style="{StaticResource MetricValue}"/>
                            </StackPanel>

                            <!-- Measured Gamma -->
                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,12">
                                <TextBlock Text="Measured Gamma" Style="{StaticResource MetricLabel}"/>
                                <TextBlock Text="{Binding MeasuredGammaText}" Style="{StaticResource MetricValue}"/>
                            </StackPanel>

                            <!-- White Point CCT -->
                            <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,0,12">
                                <TextBlock Text="White Point CCT" Style="{StaticResource MetricLabel}"/>
                                <TextBlock Text="{Binding WhitePointCctText}" Style="{StaticResource MetricValue}"/>
                            </StackPanel>

                            <!-- White Point Duv -->
                            <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,0,12">
                                <TextBlock Text="White Point Duv" Style="{StaticResource MetricLabel}"/>
                                <TextBlock Text="{Binding WhitePointDuvText}" Style="{StaticResource MetricValue}"/>
                            </StackPanel>

                            <!-- Gamut Coverage -->
                            <StackPanel Grid.Row="3" Grid.Column="0">
                                <TextBlock Text="sRGB Coverage" Style="{StaticResource MetricLabel}"/>
                                <TextBlock Text="{Binding SrgbCoverageText}" Style="{StaticResource MetricValue}"/>
                            </StackPanel>

                            <!-- Target -->
                            <StackPanel Grid.Row="3" Grid.Column="1">
                                <TextBlock Text="Calibration Target" Style="{StaticResource MetricLabel}"/>
                                <TextBlock Text="{Binding TargetText}" Style="{StaticResource MetricValue}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Charts (collapsed for historical reports: the curves need the raw
                     measurements, which aren't persisted in saved reports) -->
                <Border Style="{StaticResource CardBorder}"
                        Visibility="{Binding AreChartsVisible, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="Tone Response &amp; Gamut" Style="{StaticResource SectionHeader}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,4,8,12">
                                <TextBlock Text="Per-channel tone response (measured vs target)" Style="{StaticResource MetricLabel}"/>
                                <Border Background="#181818" CornerRadius="0" Height="200">
                                    <Canvas x:Name="ToneCanvas"/>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,4,0,12">
                                <TextBlock Text="Gamma tracking" Style="{StaticResource MetricLabel}"/>
                                <Border Background="#181818" CornerRadius="0" Height="200">
                                    <Canvas x:Name="GammaCanvas"/>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,4,8,0">
                                <TextBlock Text="Grayscale RGB balance" Style="{StaticResource MetricLabel}"/>
                                <Border Background="#181818" CornerRadius="0" Height="200">
                                    <Canvas x:Name="BalanceCanvas"/>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,4,0,0">
                                <TextBlock Text="Gamut + white point (CIE xy)" Style="{StaticResource MetricLabel}"/>
                                <Border Background="#181818" CornerRadius="0" Height="200">
                                    <Canvas x:Name="GamutCanvas"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                        <TextBlock FontSize="11" Foreground="#707070" Margin="0,8,0,0" TextWrapping="Wrap"
                                   Text="Dashed = target · orange = native (before) · green = corrected, re-measured through the applied profile. Orange dot = measured white, gray dot = target white."/>
                    </StackPanel>
                </Border>

                <!-- Shown in place of the charts for historical reports -->
                <Border Style="{StaticResource CardBorder}"
                        Visibility="{Binding IsChartsNoteVisible, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="Tone Response &amp; Gamut" Style="{StaticResource SectionHeader}"/>
                        <TextBlock Text="Charts are generated at calibration time and aren't stored in saved reports."
                                   FontSize="12" Foreground="#808080" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Detailed Verification (collapsed unless a detailed sweep ran; historical
                     reports rebuild it from the persisted per-patch results) -->
                <Border Style="{StaticResource CardBorder}"
                        Visibility="{Binding HasDetailedResults, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="Detailed Verification" Style="{StaticResource SectionHeader}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,4,8,12">
                                <TextBlock Text="ΔE distribution" Style="{StaticResource MetricLabel}"/>
                                <Border Background="#181818" CornerRadius="0" Height="200">
                                    <Canvas x:Name="HistogramCanvas"/>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="8,4,0,12">
                                <TextBlock Text="Per-patch ΔE (measurement order, hover for names)" Style="{StaticResource MetricLabel}"/>
                                <Border Background="#181818" CornerRadius="0" Height="200">
                                    <Canvas x:Name="PerPatchCanvas"/>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="{Binding CategoryBreakdownText}"
                                   FontSize="12" Foreground="#a0a0a0" TextWrapping="Wrap" Margin="0,0,0,12"/>

                        <Grid>
                            <Grid.Resources>
                                <!-- Shared row template for the worst/best patch lists. -->
                                <DataTemplate x:Key="PatchRowTemplate">
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="28"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="48"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Rank}" FontSize="12" Foreground="#707070"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="12" Foreground="#e0e0e0" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="2" Text="{Binding DeltaEText}" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{Binding DeltaEBrush}"/>
                                    </Grid>
                                </DataTemplate>
                            </Grid.Resources>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="Worst 10 patches" Style="{StaticResource MetricLabel}"/>
                                <ItemsControl ItemsSource="{Binding WorstPatches}" ItemTemplate="{StaticResource PatchRowTemplate}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <TextBlock Text="Best 10 patches" Style="{StaticResource MetricLabel}"/>
                                <ItemsControl ItemsSource="{Binding BestPatches}" ItemTemplate="{StaticResource PatchRowTemplate}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Primaries Comparison -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="Color Primaries" Style="{StaticResource SectionHeader}"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Headers -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="" Style="{StaticResource MetricLabel}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="Measured" Style="{StaticResource MetricLabel}"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Target" Style="{StaticResource MetricLabel}"/>
                            <TextBlock Grid.Row="0" Grid.Column="3" Text="Error" Style="{StaticResource MetricLabel}"/>

                            <!-- Red -->
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Red" Foreground="#ef4444" Style="{StaticResource MetricValue}"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding RedMeasuredText}" Style="{StaticResource MetricValue}"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding RedTargetText}" Style="{StaticResource MetricValue}"/>
                            <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding RedErrorText}" Style="{StaticResource MetricValue}"/>

                            <!-- Green -->
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Green" Foreground="#22c55e" Style="{StaticResource MetricValue}"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding GreenMeasuredText}" Style="{StaticResource MetricValue}"/>
                            <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding GreenTargetText}" Style="{StaticResource MetricValue}"/>
                            <TextBlock Grid.Row="2" Grid.Column="3" Text="{Binding GreenErrorText}" Style="{StaticResource MetricValue}"/>

                            <!-- Blue -->
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Blue" Foreground="#3b82f6" Style="{StaticResource MetricValue}"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding BlueMeasuredText}" Style="{StaticResource MetricValue}"/>
                            <TextBlock Grid.Row="3" Grid.Column="2" Text="{Binding BlueTargetText}" Style="{StaticResource MetricValue}"/>
                            <TextBlock Grid.Row="3" Grid.Column="3" Text="{Binding BlueErrorText}" Style="{StaticResource MetricValue}"/>

                            <!-- White -->
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="White" Style="{StaticResource MetricValue}"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding WhiteMeasuredText}" Style="{StaticResource MetricValue}"/>
                            <TextBlock Grid.Row="4" Grid.Column="2" Text="{Binding WhiteTargetText}" Style="{StaticResource MetricValue}"/>
                            <TextBlock Grid.Row="4" Grid.Column="3" Text="{Binding WhiteErrorText}" Style="{StaticResource MetricValue}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Calibration Info -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="Calibration Details" Style="{StaticResource SectionHeader}"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,12">
                                <TextBlock Text="Patches Measured" Style="{StaticResource MetricLabel}"/>
                                <TextBlock Text="{Binding PatchCountText}" Style="{StaticResource MetricValue}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,12">
                                <TextBlock Text="Measurement Time" Style="{StaticResource MetricLabel}"/>
                                <TextBlock Text="{Binding MeasurementTimeText}" Style="{StaticResource MetricValue}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,12">
                                <TextBlock Text="Colorimeter" Style="{StaticResource MetricLabel}"/>
                                <TextBlock Text="{Binding ColorimeterText}" Style="{StaticResource MetricValue}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,12">
                                <TextBlock Text="LUT Size" Style="{StaticResource MetricLabel}"/>
                                <TextBlock Text="{Binding LutSizeText}" Style="{StaticResource MetricValue}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2">
                                <TextBlock Text="Profile Location" Style="{StaticResource MetricLabel}"/>
                                <TextBlock Text="{Binding ProfilePathText}" Style="{StaticResource MetricValue}" TextWrapping="Wrap" FontSize="11"/>
                            </StackPanel>

                            <Border Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                                    Margin="0,12,0,0"
                                    Padding="10"
                                    BorderBrush="{Binding MeasurementValidationBrush}"
                                    BorderThickness="1"
                                    Background="{DynamicResource ThemeBg}"
                                    Visibility="{Binding IsMeasurementValidationVisible, Converter={StaticResource BoolToVis}}">
                                <StackPanel>
                                    <TextBlock Text="Measurement Integrity" Style="{StaticResource MetricLabel}"/>
                                    <TextBlock Text="{Binding MeasurementValidationText}"
                                               Foreground="{Binding MeasurementValidationBrush}"
                                               TextWrapping="Wrap"
                                               FontSize="12"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Recommendations -->
                <Border Style="{StaticResource CardBorder}" x:Name="RecommendationsPanel">
                    <StackPanel>
                        <TextBlock Text="Recommendations" Style="{StaticResource SectionHeader}"/>
                        <ItemsControl ItemsSource="{Binding Recommendations}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,4">
                                        <TextBlock Text="*" Foreground="{DynamicResource ThemeAccent}" FontWeight="Bold" Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding}" TextWrapping="Wrap" Foreground="{DynamicResource ThemeTextDim}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer with Actions. The Detailed verification checkbox is pinned left in its
             own flexible "*" column and the action buttons are right-aligned in an "Auto"
             column, with the gap between them absorbing the slack. Previously every control
             sat in its own Auto column with no flexible column, so at MinWidth the row had
             nowhere to give and the leftmost button was pushed off the left edge and clipped. -->
        <Border Grid.Row="2" Background="{DynamicResource ThemeSurface}" BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="0,1,0,0" Padding="20,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <CheckBox Grid.Column="0"
                          x:Name="DetailedVerifyCheck"
                          Content="Detailed verification"
                          IsChecked="{Binding IsDetailedVerifyChecked}"
                          IsEnabled="{Binding IsVerifyEnabled}"
                          ToolTip="Extends the verify sweep to a 21-step grayscale, R/G/B saturation ramps and the ColorChecker memory colors (39 patches), adding a ΔE distribution, per-patch chart, worst/best patch lists and a category breakdown to the report. Takes several times longer than the standard verify."
                          Foreground="{DynamicResource ThemeText}"
                          VerticalAlignment="Center" HorizontalAlignment="Left"
                          Margin="0,0,16,0"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="ExportReportButton"
                            Content="Export Report"
                            ToolTip="Print or save as PDF via Microsoft Print to PDF"
                            Style="{StaticResource BrutBtnSecondary}"
                            Margin="0,0,10,0"
                            Click="ExportReportButton_Click"/>

                    <Button x:Name="ExportButton"
                            Content="Export LUT"
                            Style="{StaticResource BrutBtnSecondary}"
                            Margin="0,0,10,0"
                            Click="ExportButton_Click"/>

                    <Button x:Name="ApplyButton"
                            Content="{Binding ApplyButtonContent}"
                            IsEnabled="{Binding IsApplyEnabled}"
                            Style="{StaticResource BrutBtnPrimary}"
                            Margin="0,0,10,0"
                            Click="ApplyButton_Click"/>

                    <Button x:Name="VerifyButton"
                            Content="{Binding VerifyButtonContent}"
                            IsEnabled="{Binding IsVerifyEnabled}"
                            ToolTip="Re-measure a quick patch sweep through the applied profile to refresh the 'after' numbers. Place the probe on the display first."
                            Style="{StaticResource BrutBtnSecondary}"
                            Margin="0,0,10,0"
                            Click="VerifyButton_Click"/>

                    <Button x:Name="WhiteToolsButton"
                            Content="White Tools"
                            IsEnabled="{Binding IsWhiteToolsEnabled}"
                            ToolTip="Re-anchor white with a quick measurement (drift fix), or trim the target white by eye against a reference display."
                            Style="{StaticResource BrutBtnSecondary}"
                            Margin="0,0,10,0"
                            Click="WhiteToolsButton_Click"/>

                    <Button Content="Close"
                            IsEnabled="{Binding IsCloseEnabled}"
                            Style="{StaticResource BrutBtnSecondary}"
                            Click="CloseButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
    </Border>
</Window>
