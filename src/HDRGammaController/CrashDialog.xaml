<Window x:Class="HDRGammaController.CrashDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:HDRGammaController.ViewModels"
        Title="Gloam — Error"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        SizeToContent="WidthAndHeight"
        MinWidth="420"
        MaxWidth="560"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        d:DataContext="{d:DesignInstance Type=vm:CrashDialogViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Brutalist.xaml"/>
                <ResourceDictionary Source="Themes/Overlays.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        </ResourceDictionary>
    </Window.Resources>

    <Border Style="{StaticResource OverlayCard}">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header: accent-red kicker + title -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                <Border Width="4" Background="{DynamicResource ThemeAccent}" Margin="0,0,10,0"/>
                <TextBlock Style="{StaticResource Kicker}" Text="ERROR" VerticalAlignment="Center"/>
            </StackPanel>

            <TextBlock Grid.Row="1" Style="{StaticResource OverlayTitle}"
                       FontSize="16" Text="{Binding Message}" Margin="0,0,0,12"/>

            <!-- Expandable details -->
            <StackPanel Grid.Row="2" Margin="0,0,0,8"
                        Visibility="{Binding HasDetails, Converter={StaticResource BoolToVis}}">
                <Button Style="{StaticResource BrutBtnSecondary}"
                        HorizontalAlignment="Left" Padding="10,4"
                        Command="{Binding ToggleDetailsCommand}">
                    <TextBlock>
                        <Run Text="Details"/>
                        <Run Text="{Binding AreDetailsVisible, Mode=OneWay, StringFormat=' [{0}]'}"/>
                    </TextBlock>
                </Button>
                <Border Background="{DynamicResource ThemeBg}" Margin="0,8,0,0"
                        BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1"
                        Padding="10" MaxHeight="200"
                        Visibility="{Binding AreDetailsVisible, Converter={StaticResource BoolToVis}}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <TextBlock Style="{StaticResource OverlayDetail}" Text="{Binding Details}"/>
                    </ScrollViewer>
                </Border>
            </StackPanel>

            <!-- Copy button (when details exist) -->
            <Button Grid.Row="3" Style="{StaticResource BrutBtnSecondary}"
                    HorizontalAlignment="Left" Padding="12,5" Margin="0,0,0,12"
                    Content="Copy details"
                    Command="{Binding CopyDetailsCommand}"
                    Visibility="{Binding HasDetails, Converter={StaticResource BoolToVis}}"/>

            <!-- Actions: Continue (secondary) | Exit (primary) -->
            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource BrutBtnSecondary}"
                        Content="Continue" Padding="18,9" Margin="0,0,10,0"
                        Command="{Binding ContinueCommand}"/>
                <Button Style="{StaticResource BrutBtnPrimary}"
                        Content="Exit" Padding="18,9"
                        Command="{Binding ExitCommand}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
