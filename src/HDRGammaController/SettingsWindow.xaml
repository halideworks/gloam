<Window x:Class="HDRGammaController.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:HDRGammaController"
        xmlns:behaviors="clr-namespace:HDRGammaController.Behaviors"
        Title="Gloam - Settings"
        Width="540" Height="760"
        MinWidth="500" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        Foreground="{DynamicResource ThemeText}"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Gloam;component/Themes/Brutalist.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Brutalist slider: square track, square accent thumb, optional center tick -->
            <Style x:Key="ModernSlider" TargetType="Slider">
                <Setter Property="Height" Value="24"/>
                <Setter Property="Margin" Value="0,4"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Slider">
                            <Grid>
                                <Border Height="4" VerticalAlignment="Center" Background="{DynamicResource ThemeTrack}"/>
                                <Track x:Name="PART_Track">
                                    <Track.Thumb>
                                        <Thumb>
                                            <Thumb.Template>
                                                <ControlTemplate TargetType="Thumb">
                                                    <Rectangle Width="14" Height="14" Fill="{DynamicResource ThemeAccent}"/>
                                                </ControlTemplate>
                                            </Thumb.Template>
                                        </Thumb>
                                    </Track.Thumb>
                                </Track>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="CenteredSlider" TargetType="Slider">
                <Setter Property="Height" Value="24"/>
                <Setter Property="Margin" Value="0,4"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Slider">
                            <Grid>
                                <Border Height="4" VerticalAlignment="Center" Background="{DynamicResource ThemeTrack}"/>
                                <Rectangle Width="2" Height="12" Fill="{DynamicResource ThemeTextDim}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" ToolTip="Default: 0"/>
                                <Track x:Name="PART_Track">
                                    <Track.Thumb>
                                        <Thumb>
                                            <Thumb.Template>
                                                <ControlTemplate TargetType="Thumb">
                                                    <Rectangle Width="14" Height="14" Fill="{DynamicResource ThemeAccent}"/>
                                                </ControlTemplate>
                                            </Thumb.Template>
                                        </Thumb>
                                    </Track.Thumb>
                                </Track>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="RgbSlider" TargetType="Slider">
                <Setter Property="Height" Value="24"/>
                <Setter Property="Margin" Value="0,4"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Slider">
                            <Grid>
                                <Border Height="4" VerticalAlignment="Center" Background="{DynamicResource ThemeTrack}"/>
                                <Rectangle Width="2" Height="12" Fill="{DynamicResource ThemeTextDim}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" ToolTip="Default: 1.0"/>
                                <Track x:Name="PART_Track">
                                    <Track.Thumb>
                                        <Thumb>
                                            <Thumb.Template>
                                                <ControlTemplate TargetType="Thumb">
                                                    <Rectangle Width="14" Height="14" Fill="{DynamicResource ThemeAccent}"/>
                                                </ControlTemplate>
                                            </Thumb.Template>
                                        </Thumb>
                                    </Track.Thumb>
                                </Track>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Mono value readout -->
            <Style x:Key="ValueDisplay" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{DynamicResource MonoFont}"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Foreground" Value="{DynamicResource ThemeText}"/>
                <Setter Property="HorizontalAlignment" Value="Right"/>
            </Style>

            <Style x:Key="EditableValue" TargetType="TextBlock" BasedOn="{StaticResource ValueDisplay}">
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="ToolTip" Value="Click to enter value"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Margin" Value="8,0,0,0"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Foreground" Value="{DynamicResource ThemeAccent}"/>
                        <Setter Property="TextDecorations" Value="Underline"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Section card: hard square border -->
            <Style x:Key="SectionCard" TargetType="Border">
                <Setter Property="Background" Value="{DynamicResource ThemeSurface}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorder}"/>
                <Setter Property="BorderThickness" Value="2"/>
                <Setter Property="Padding" Value="16"/>
                <Setter Property="Margin" Value="0,0,0,12"/>
            </Style>

            <Style x:Key="SectionHeader" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{DynamicResource DisplayFont}"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Foreground" Value="{DynamicResource ThemeText}"/>
                <Setter Property="Margin" Value="0,0,0,12"/>
            </Style>

            <Style x:Key="FieldLabel" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{DynamicResource DisplayFont}"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Foreground" Value="{DynamicResource ThemeTextDim}"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="Margin" Value="0,8,0,4"/>
            </Style>

            <!-- Buttons reuse the shared brutalist templates -->
            <Style x:Key="ModernButton" TargetType="Button" BasedOn="{StaticResource BrutBtnPrimary}"/>
            <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource BrutBtnSecondary}"/>

            <Style x:Key="ModernToggle" TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
                <Setter Property="Margin" Value="0,4"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <!-- Outer frame: black in both themes (visible on light, seamless on dark) -->
    <Border Background="{DynamicResource ThemeBg}" BorderBrush="{DynamicResource ThemeWindowFrame}" BorderThickness="2">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Custom Title Bar -->
            <Border Grid.Row="0" Background="{DynamicResource ThemeSurface}"
                    BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="0,0,0,3"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid Margin="16,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <local:BrandMark Width="20" Height="20" Margin="0,0,10,0" VerticalAlignment="Center" GapBrush="{DynamicResource ThemeSurface}"/>
                        <TextBlock Text="GLOAM" FontFamily="{DynamicResource DisplayFont}" FontWeight="ExtraBold"
                                   FontSize="14" Foreground="{DynamicResource ThemeText}" VerticalAlignment="Center"/>
                        <Border Width="1" Height="14" Background="{DynamicResource ThemeTextDim}" Opacity="0.5" Margin="10,0"/>
                        <TextBlock Text="SETTINGS" FontFamily="{DynamicResource DisplayFont}" FontWeight="Bold"
                                   FontSize="11" Foreground="{DynamicResource ThemeTextDim}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Content="&#x2715;" HorizontalAlignment="Right" VerticalAlignment="Center"
                            Width="30" Height="30" FontSize="13"
                            Style="{StaticResource BrutIconButton}" Click="Close_Click" ToolTip="Close"/>
                </Grid>
            </Border>

            <!-- Main Content -->
            <Grid Grid.Row="1" Margin="20,14,20,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Monitor Selector Header -->
                <StackPanel Grid.Row="0" Margin="0,0,0,16">
                    <TextBlock Text="MONITOR" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding Monitors}" DisplayMemberPath="Label"
                              SelectedItem="{Binding SelectedMonitor}"/>
                </StackPanel>

                <!-- Scrollable Content -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden" Padding="0,0,4,0">
                    <StackPanel>

                        <!-- Gamma Section -->
                        <Border Style="{StaticResource SectionCard}">
                            <StackPanel>
                                <TextBlock Text="GAMMA" Style="{StaticResource SectionHeader}"/>
                                <ComboBox SelectedIndex="{Binding GammaModeIndex}">
                                    <ComboBoxItem Content="Gamma 2.2"/>
                                    <ComboBoxItem Content="Gamma 2.4"/>
                                    <ComboBoxItem Content="Windows Default"/>
                                </ComboBox>
                            </StackPanel>
                        </Border>

                        <!-- Brightness/Dimming Section -->
                        <Border Style="{StaticResource SectionCard}">
                            <StackPanel>
                                <Grid>
                                    <TextBlock Text="BRIGHTNESS" Style="{StaticResource SectionHeader}"/>
                                    <TextBlock Text="{Binding Value, ElementName=BrightnessSlider, StringFormat={}{0:F0}%}" Style="{StaticResource ValueDisplay}"/>
                                </Grid>
                                <Slider x:Name="BrightnessSlider" IsSnapToTickEnabled="True" TickFrequency="1" Style="{StaticResource ModernSlider}"
                                        Minimum="10" Maximum="100"
                                        Value="{Binding Brightness}"/>
                                <CheckBox Content="Enhance shadow detail (Recommended)"
                                          ToolTip="When dimming, slightly lifts shadows to prevent them from becoming invisible (black crush)."
                                          Style="{StaticResource ModernToggle}" Margin="0,8,0,0"
                                          IsChecked="{Binding EnhanceShadows}"/>

                                <!-- Quick Presets -->
                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                    <Button Content="100%" Style="{StaticResource ModernButton}"
                                            Command="{Binding SetBrightnessCommand}" CommandParameter="100" Margin="0,0,8,0"/>
                                    <Button Content="75%" Style="{StaticResource ModernButton}"
                                            Command="{Binding SetBrightnessCommand}" CommandParameter="75" Margin="0,0,8,0"/>
                                    <Button Content="50%" Style="{StaticResource ModernButton}"
                                            Command="{Binding SetBrightnessCommand}" CommandParameter="50"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Temperature/Tint Section -->
                        <Border Style="{StaticResource SectionCard}">
                            <StackPanel>
                                <TextBlock Text="COLOR TEMPERATURE" Style="{StaticResource SectionHeader}"/>

                                <TextBlock Text="TEMPERATURE" Style="{StaticResource FieldLabel}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Slider x:Name="TemperatureSlider" IsSnapToTickEnabled="True" TickFrequency="1" Grid.Column="0" Style="{StaticResource CenteredSlider}"
                                            Minimum="-50" Maximum="50"
                                            Value="{Binding Temperature}"
                                            behaviors:SliderDetent.IsEnabled="True"
                                            behaviors:SliderDetent.DetentValue="0"
                                            behaviors:SliderDetent.SnapThreshold="2"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Value, ElementName=TemperatureSlider, StringFormat={}{0:F0}}"
                                               Style="{StaticResource EditableValue}" Width="40"
                                               behaviors:ClickToEdit.TargetSlider="{Binding ElementName=TemperatureSlider}"/>
                                </Grid>
                                <Grid>
                                    <TextBlock Text="Warm" Foreground="{DynamicResource ThemeTextDim}" FontSize="10"/>
                                    <TextBlock Text="Cool" Foreground="{DynamicResource ThemeTextDim}" FontSize="10"
                                               HorizontalAlignment="Right"/>
                                </Grid>

                                <!-- Tint Section -->
                                <TextBlock Text="TINT" Style="{StaticResource FieldLabel}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Slider x:Name="TintSlider" IsSnapToTickEnabled="True" TickFrequency="1" Grid.Column="0" Style="{StaticResource CenteredSlider}"
                                            Minimum="-50" Maximum="50"
                                            Value="{Binding Tint}"
                                            behaviors:SliderDetent.IsEnabled="True"
                                            behaviors:SliderDetent.DetentValue="0"
                                            behaviors:SliderDetent.SnapThreshold="2"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Value, ElementName=TintSlider, StringFormat={}{0:F0}}"
                                               Style="{StaticResource EditableValue}" Width="40"
                                               behaviors:ClickToEdit.TargetSlider="{Binding ElementName=TintSlider}"/>
                                </Grid>
                                <Grid>
                                    <TextBlock Text="Green" Foreground="{DynamicResource ThemeTextDim}" FontSize="10"/>
                                    <TextBlock Text="Magenta" Foreground="{DynamicResource ThemeTextDim}" FontSize="10"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Night Mode Section -->
                        <Border Style="{StaticResource SectionCard}">
                            <StackPanel>
                                <TextBlock Text="NIGHT MODE" Style="{StaticResource SectionHeader}"/>

                                <!-- Global Settings Moved to Dashboard -->
                                <TextBlock Text="Global Night Mode settings are now managed in the Dashboard."
                                           Foreground="{DynamicResource ThemeTextDim}" FontSize="12" Margin="0,0,0,16" TextWrapping="Wrap"/>

                                <!-- Per Monitor Settings -->
                                <Separator Margin="0,16,0,16" Background="{DynamicResource ThemeBorder}"/>
                                <TextBlock Text="PER-MONITOR OVERRIDE" Style="{StaticResource SectionHeader}" FontSize="11" Margin="0,0,0,8" Foreground="{DynamicResource ThemeTextDim}"/>
                                <TextBlock Text="Fine-tune this monitor's temperature relative to the global setting."
                                           Foreground="{DynamicResource ThemeTextDim}" FontSize="11" Margin="0,-4,0,12" TextWrapping="Wrap"/>

                                <TextBlock Text="TEMPERATURE OFFSET" Style="{StaticResource FieldLabel}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Slider x:Name="TempOffsetSlider" IsSnapToTickEnabled="True" TickFrequency="1" Grid.Column="0" Style="{StaticResource CenteredSlider}"
                                            Minimum="-20" Maximum="20"
                                            Value="{Binding TemperatureOffset}"
                                            behaviors:SliderDetent.IsEnabled="True"
                                            behaviors:SliderDetent.DetentValue="0"
                                            behaviors:SliderDetent.SnapThreshold="1"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Value, ElementName=TempOffsetSlider, StringFormat={}{0:F0}}"
                                               Style="{StaticResource EditableValue}" Width="40"
                                               behaviors:ClickToEdit.TargetSlider="{Binding ElementName=TempOffsetSlider}"/>
                                </Grid>
                                <Grid>
                                    <TextBlock Text="Warmer" Foreground="{DynamicResource ThemeTextDim}" FontSize="10"/>
                                    <TextBlock Text="Cooler" Foreground="{DynamicResource ThemeTextDim}" FontSize="10"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- RGB Fine Tuning Section -->
                        <Border Style="{StaticResource SectionCard}">
                            <Expander Header="RGB FINE TUNING" Foreground="{DynamicResource ThemeText}" FontFamily="{DynamicResource DisplayFont}" FontWeight="Bold" IsExpanded="False">
                                <StackPanel Margin="0,12,0,0">
                                    <!-- Red -->
                                    <TextBlock Text="RED GAIN" Style="{StaticResource FieldLabel}"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Slider x:Name="RedGainSlider" Grid.Column="0" Style="{StaticResource RgbSlider}"
                                                Minimum="0.5" Maximum="1.5" TickFrequency="0.01"
                                                Value="{Binding RedGain}"
                                                behaviors:SliderDetent.IsEnabled="True"
                                                behaviors:SliderDetent.DetentValue="1.0"
                                                behaviors:SliderDetent.SnapThreshold="0.03"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Value, ElementName=RedGainSlider, StringFormat={}{0:F2}}"
                                                   Style="{StaticResource EditableValue}" Width="40"
                                                   behaviors:ClickToEdit.TargetSlider="{Binding ElementName=RedGainSlider}"/>
                                    </Grid>

                                    <!-- Green -->
                                    <TextBlock Text="GREEN GAIN" Style="{StaticResource FieldLabel}"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Slider x:Name="GreenGainSlider" Grid.Column="0" Style="{StaticResource RgbSlider}"
                                                Minimum="0.5" Maximum="1.5" TickFrequency="0.01"
                                                Value="{Binding GreenGain}"
                                                behaviors:SliderDetent.IsEnabled="True"
                                                behaviors:SliderDetent.DetentValue="1.0"
                                                behaviors:SliderDetent.SnapThreshold="0.03"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Value, ElementName=GreenGainSlider, StringFormat={}{0:F2}}"
                                                   Style="{StaticResource EditableValue}" Width="40"
                                                   behaviors:ClickToEdit.TargetSlider="{Binding ElementName=GreenGainSlider}"/>
                                    </Grid>

                                    <!-- Blue -->
                                    <TextBlock Text="BLUE GAIN" Style="{StaticResource FieldLabel}"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Slider x:Name="BlueGainSlider" Grid.Column="0" Style="{StaticResource RgbSlider}"
                                                Minimum="0.5" Maximum="1.5" TickFrequency="0.01"
                                                Value="{Binding BlueGain}"
                                                behaviors:SliderDetent.IsEnabled="True"
                                                behaviors:SliderDetent.DetentValue="1.0"
                                                behaviors:SliderDetent.SnapThreshold="0.03"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Value, ElementName=BlueGainSlider, StringFormat={}{0:F2}}"
                                                   Style="{StaticResource EditableValue}" Width="40"
                                                   behaviors:ClickToEdit.TargetSlider="{Binding ElementName=BlueGainSlider}"/>
                                    </Grid>

                                    <Button Content="RESET RGB" Style="{StaticResource ModernButton}"
                                            Command="{Binding ResetRgbCommand}" Margin="0,12,0,0" HorizontalAlignment="Left"/>
                                </StackPanel>
                            </Expander>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- Footer. Live Preview sits on its own row ABOVE the action buttons so the two
                     never compete for horizontal space. Earlier single-row layouts (a right-
                     aligned StackPanel, then a 2-column grid) still let the button group overlap
                     and clip the checkbox to "Live P" once the Apply button appeared. -->
                <StackPanel Grid.Row="2" Margin="0,16,0,0">
                    <CheckBox Content="Live Preview"
                              Foreground="{DynamicResource ThemeText}"
                              HorizontalAlignment="Left" Margin="0,0,0,10"
                              IsChecked="{Binding IsLivePreview}"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Apply" Command="{Binding ApplyCommand}" Margin="0,0,8,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ModernButton}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLivePreview}" Value="False">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Compare (Hold)" Style="{StaticResource SecondaryButton}"
                                PreviewMouseDown="Compare_MouseDown" PreviewMouseUp="Compare_MouseUp"
                                Margin="0,0,8,0"/>
                        <Button Content="Reset All" Style="{StaticResource SecondaryButton}"
                                Command="{Binding ResetAllCommand}" Margin="0,0,8,0"/>
                        <Button Content="Save &amp; Close" Style="{StaticResource ModernButton}"
                                Command="{Binding SaveAndCloseCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
