<Window x:Class="HDRGammaController.CalibrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:HDRGammaController.ViewModels"
        Title="Display Calibration Finalize"
        Width="600" Height="700"
        MinWidth="560" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        Foreground="White"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <!-- Colors -->
        <SolidColorBrush x:Key="AccentBrush" Color="#0078D4"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#1084D8"/>
        <SolidColorBrush x:Key="WarningBrush" Color="#FFA500"/>
        <SolidColorBrush x:Key="WarningBackgroundBrush" Color="#3D2800"/>
        <SolidColorBrush x:Key="DarkSurround" Color="#1A1A1A"/>
        <SolidColorBrush x:Key="CardBackground" Color="#2D2D2D"/>
        <SolidColorBrush x:Key="CardBorder" Color="#3F3F3F"/>
        <SolidColorBrush x:Key="TextDim" Color="#888888"/>
        <SolidColorBrush x:Key="ProgressBackground" Color="#333333"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#4CAF50"/>
        <SolidColorBrush x:Key="ErrorBrush" Color="#F44336"/>

        <!-- Modern Button Style -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Subtle Button Style -->
        <Style x:Key="SubtleButton" TargetType="Button">
            <Setter Property="Background" Value="#444444"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#555555"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Radio Button Style -->
        <Style x:Key="ModernRadioButton" TargetType="RadioButton">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" Background="Transparent" BorderBrush="{StaticResource CardBorder}"
                                BorderThickness="1" CornerRadius="4" Padding="12,10" Cursor="Hand">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Ellipse x:Name="outerCircle" Width="18" Height="18"
                                         Stroke="{StaticResource CardBorder}" StrokeThickness="2" Fill="Transparent"/>
                                <Ellipse x:Name="innerCircle" Width="10" Height="10"
                                         Fill="{StaticResource AccentBrush}" Visibility="Collapsed"/>
                                <ContentPresenter Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="outerCircle" Property="Stroke" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="innerCircle" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#333333"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Progress Bar Style -->
        <Style x:Key="CalibrationProgressBar" TargetType="ProgressBar">
            <Setter Property="Height" Value="8"/>
            <Setter Property="Background" Value="{StaticResource ProgressBackground}"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid>
                            <Border x:Name="PART_Track" Background="{TemplateBinding Background}"
                                    CornerRadius="4"/>
                            <Border x:Name="PART_Indicator" Background="{TemplateBinding Foreground}"
                                    CornerRadius="4" HorizontalAlignment="Left"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark Mode ComboBox Style -->
        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource CardBackground}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" Grid.Column="2" Focusable="false"
                                          IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Border" Background="{StaticResource CardBackground}"
                                                BorderBrush="{StaticResource CardBorder}" BorderThickness="1"
                                                CornerRadius="4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition/>
                                                    <ColumnDefinition Width="20"/>
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0"/>
                                                <Path x:Name="Arrow" Grid.Column="1" Fill="White"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      Data="M 0 0 L 4 4 L 8 0 Z"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="#3D3D3D"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              Margin="10,8,25,8" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid x:Name="DropDown" SnapsToDevicePixels="True"
                                      MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder" Background="#2D2D2D"
                                            BorderBrush="{StaticResource CardBorder}" BorderThickness="1" CornerRadius="4"/>
                                    <ScrollViewer Margin="4,6,4,6" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark Mode ComboBoxItem Style - Must use x:Key and apply via ItemContainerStyle for popups -->
        <Style x:Key="DarkComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Border" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}" CornerRadius="2">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#444444"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark Mode ScrollBar Style - MUST be defined before ScrollViewer that uses it -->
        <Style x:Key="DarkScrollBar" TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Border Background="#252525" CornerRadius="5"/>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#555555" CornerRadius="5" Margin="2"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto"/>
                    <Setter Property="Height" Value="10"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Dark Mode ScrollViewer Style -->
        <Style TargetType="ScrollViewer">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <!-- Margin binding is what makes the ScrollViewer's declared Padding
                                 actually apply; without it content rides the window edge. -->
                            <ScrollContentPresenter Grid.Column="0" Grid.Row="0" Margin="{TemplateBinding Padding}"/>
                            <ScrollBar x:Name="PART_VerticalScrollBar" Grid.Column="1" Grid.Row="0"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                       Style="{StaticResource DarkScrollBar}"/>
                            <ScrollBar x:Name="PART_HorizontalScrollBar" Grid.Column="0" Grid.Row="1"
                                       Orientation="Horizontal"
                                       Value="{TemplateBinding HorizontalOffset}"
                                       Maximum="{TemplateBinding ScrollableWidth}"
                                       ViewportSize="{TemplateBinding ViewportWidth}"
                                       Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}"
                                       Style="{StaticResource DarkScrollBar}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="RootBorder" Background="#1E1E1E" BorderBrush="#3F3F3F" BorderThickness="1" CornerRadius="8">
    <Grid x:Name="RootGrid">
        <!-- Setup Panel (shown before calibration starts) -->
        <Grid Visibility="{Binding IsSetupVisible, Converter={StaticResource BoolToVis}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Titlebar -->
            <Border Grid.Row="0" Background="#252525" CornerRadius="8,8,0,0" MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid Margin="16,0">
                    <TextBlock Text="Display Calibration Finalize" VerticalAlignment="Center" FontWeight="Medium" FontSize="14"/>
                    <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Center"
                            Style="{StaticResource SubtleButton}" Background="Transparent"
                            Foreground="#888" Padding="8,4" Click="Cancel_Click"/>
                </Grid>
            </Border>

            <!-- Header -->
            <StackPanel Grid.Row="1" Margin="24,16,24,4">
                <TextBlock Text="Finalize Calibration" FontSize="20" FontWeight="SemiBold"/>
                <TextBlock Text="Confirm display mode and measurement options, then start calibration"
                           Foreground="{StaticResource TextDim}" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Setup Options -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="24,16">
                <StackPanel>
                    <!-- Display Mode Selection -->
                    <TextBlock Text="Display Mode" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <RadioButton Style="{StaticResource ModernRadioButton}"
                                 IsChecked="{Binding IsFullScreenMode}">
                        <StackPanel>
                            <TextBlock Text="Full-Screen (Recommended)" FontWeight="Medium"/>
                            <TextBlock Text="Best accuracy - dark surround eliminates ambient light interference"
                                       Foreground="{StaticResource TextDim}" FontSize="12" TextWrapping="Wrap"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton Style="{StaticResource ModernRadioButton}"
                                 IsChecked="{Binding IsWindowedMode}">
                        <StackPanel>
                            <TextBlock Text="Windowed Mode" FontWeight="Medium"/>
                            <TextBlock Text="Allows multitasking - position the window where your colorimeter is placed"
                                       Foreground="{StaticResource TextDim}" FontSize="12" TextWrapping="Wrap"/>
                        </StackPanel>
                    </RadioButton>

                    <!-- Warning for Windowed Mode -->
                    <Border Background="{StaticResource WarningBackgroundBrush}"
                            BorderBrush="{StaticResource WarningBrush}" BorderThickness="1"
                            CornerRadius="4" Padding="12" Margin="0,8,0,0"
                            Visibility="{Binding IsWindowedMode, Converter={StaticResource BoolToVis}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="!" FontSize="18" FontWeight="Bold" Foreground="{StaticResource WarningBrush}"
                                       VerticalAlignment="Top" Margin="0,0,10,0"/>
                            <TextBlock Grid.Column="1" TextWrapping="Wrap" Foreground="#FFD699">
                                <Run FontWeight="SemiBold">Windowed mode may reduce measurement accuracy.</Run>
                                <LineBreak/>
                                <Run>Ambient light and screen reflections can affect readings. </Run>
                                <Run>Full-screen mode is recommended for best results.</Run>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <!-- Colorimeter Status -->
                    <TextBlock Text="Colorimeter Status" FontSize="13" FontWeight="SemiBold" Margin="0,24,0,8"/>
                    <Border Background="{StaticResource CardBackground}" BorderBrush="{StaticResource CardBorder}"
                            BorderThickness="1" CornerRadius="6" Padding="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Ellipse Width="12" Height="12"
                                     Fill="{Binding ColorimeterBrush}" Margin="0,0,10,0"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding ColorimeterStatusText}" FontWeight="Medium"/>
                                <TextBlock Text="{Binding ColorimeterModelText}" Foreground="{StaticResource TextDim}" FontSize="12"/>
                            </StackPanel>
                            <Button Grid.Column="2" Content="Refresh" Style="{StaticResource SubtleButton}"
                                    Click="RefreshColorimeter_Click" Padding="8,4"/>
                        </Grid>
                    </Border>

                    <!-- Correction Bypass Warning -->
                    <Border Background="#1A3D2800"
                            BorderBrush="{StaticResource WarningBrush}" BorderThickness="1"
                            CornerRadius="4" Padding="12" Margin="0,24,0,0"
                            Visibility="{Binding ShowBypassWarning, Converter={StaticResource BoolToVis}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="ℹ" FontSize="18" Foreground="{StaticResource AccentBrush}"
                                       VerticalAlignment="Top" Margin="0,0,10,0"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock TextWrapping="Wrap" Foreground="White">
                                    <Run FontWeight="SemiBold">Color corrections will be temporarily disabled</Run>
                                </TextBlock>
                                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextDim}" Margin="0,4,0,0">
                                    Your current gamma adjustments and night mode settings will be bypassed
                                    during calibration to measure the display's native response.
                                    After calibration, you can choose to view the results with or without
                                    your previous settings applied.
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Additional Options -->
                    <TextBlock Text="Options" FontSize="13" FontWeight="SemiBold" Margin="0,24,0,8"/>
                    <CheckBox Content="Keep window on top (windowed mode)"
                              Foreground="White" IsChecked="{Binding AlwaysOnTop}" Margin="0,4"/>
                    <CheckBox Content="Play sound on completion"
                              Foreground="White" IsChecked="{Binding SoundOnCompletion}" Margin="0,4"/>
                    <CheckBox Content="Play sound on each capture"
                              Foreground="White" IsChecked="{Binding SoundOnCapture}" Margin="0,4"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer with Start Button -->
            <Border Grid.Row="3" Background="#252525" CornerRadius="0,0,8,8" Padding="24,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding PatchCountText}" Foreground="{StaticResource TextDim}"/>
                        <TextBlock Text=" • " Foreground="{StaticResource TextDim}"/>
                        <TextBlock Text="{Binding EstimatedTimeText}" Foreground="{StaticResource TextDim}"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="Back" Style="{StaticResource SubtleButton}"
                            Click="Back_Click" Margin="0,0,8,0"
                            ToolTip="Return to calibration setup to adjust target, preset or meter options"/>
                    <Button Grid.Column="2" Content="Cancel" Style="{StaticResource SubtleButton}"
                            Click="Cancel_Click" Margin="0,0,8,0"/>
                    <Button Grid.Column="3" Content="Start Calibration"
                            Style="{StaticResource ModernButton}" Click="Start_Click"
                            IsEnabled="{Binding CanStart}"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Positioning Panel (shown after clicking Start, before measurement begins) -->
        <Grid Visibility="{Binding IsPositioningVisible, Converter={StaticResource BoolToVis}}"
              Background="{StaticResource DarkSurround}"
              MouseLeftButtonDown="PatchDrag_MouseDown" MouseMove="PatchDrag_MouseMove"
              MouseLeftButtonUp="PatchDrag_MouseUp" Cursor="SizeAll">
            <!-- Windowed Mode Warning Banner -->
            <Border Background="{StaticResource WarningBackgroundBrush}"
                    VerticalAlignment="Top" Padding="8,6" Panel.ZIndex="100"
                    Visibility="{Binding ShowPositioningWindowedBanner, Converter={StaticResource BoolToVis}}">
                <TextBlock HorizontalAlignment="Center" Foreground="#FFD699" FontSize="12">
                    <Run FontWeight="SemiBold">Windowed Mode</Run>
                    <Run> - Drag anywhere to position, resize window to scale patch</Run>
                </TextBlock>
            </Border>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Preview Patch Display - Scales with window size. The RenderTransform
                     lets the user move the patch to wherever the probe hangs; the offset
                     is shared with the measurement patch so placement carries over. -->
                <Viewbox Grid.Row="0" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"
                         Margin="20">
                    <Viewbox.RenderTransform>
                        <TranslateTransform x:Name="PositioningPatchTransform"/>
                    </Viewbox.RenderTransform>
                    <Border x:Name="PositioningPatchBorder" Width="400" Height="400"
                            Background="White" BorderThickness="0">
                        <!-- Probe-placement target: align the colorimeter's sensor over the
                             center ring. Muted gray so it guides placement without skewing
                             the white reference; the actual measurement uses a clean patch. -->
                        <Grid x:Name="ProbeTargetOverlay">
                            <Ellipse Width="150" Height="150" Stroke="#9AA0A6" StrokeThickness="2"
                                     StrokeDashArray="4 3" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Ellipse Width="92" Height="92" Stroke="#7A7F85" StrokeThickness="2"
                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Rectangle Width="2" Height="44" Fill="#7A7F85"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Rectangle Width="44" Height="2" Fill="#7A7F85"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Ellipse Width="8" Height="8" Fill="#5F6368"
                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </Viewbox>

                <!-- Positioning Instructions -->
                <Border Grid.Row="1" Background="#CC1A1A1A" Padding="24,20">
                    <StackPanel MaxWidth="600" HorizontalAlignment="Center">
                        <TextBlock Text="Position Your Colorimeter" FontSize="18" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" Margin="0,0,0,12"/>
                        <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextDim}" FontSize="13"
                                   HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,16">
                            Hang the colorimeter with its counterweight over the top of the
                            display, then <Run FontWeight="SemiBold">drag the target</Run> (or use the
                            <Run FontWeight="SemiBold">arrow keys</Run>) so the crosshair sits directly
                            under the sensor, flush against the screen. This position carries into
                            measurement, so click Begin Measurement once it's aligned.
                        </TextBlock>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="Back" Style="{StaticResource SubtleButton}"
                                    Click="PositioningBack_Click" Margin="0,0,12,0" Padding="20,10"/>
                            <Button Content="Begin Measurement"
                                    Style="{StaticResource ModernButton}" Click="BeginMeasurement_Click" Padding="24,10"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- Measurement Panel (shown during calibration) -->
        <Grid Visibility="{Binding IsMeasurementVisible, Converter={StaticResource BoolToVis}}"
              Background="{StaticResource DarkSurround}"
              MouseLeftButtonDown="PatchDrag_MouseDown" MouseMove="PatchDrag_MouseMove"
              MouseLeftButtonUp="PatchDrag_MouseUp" Cursor="SizeAll">
            <!-- Windowed Mode Warning Banner -->
            <Border Background="{StaticResource WarningBackgroundBrush}"
                    VerticalAlignment="Top" Padding="8,6" Panel.ZIndex="100"
                    Visibility="{Binding ShowWindowedModeBanner, Converter={StaticResource BoolToVis}}">
                <TextBlock HorizontalAlignment="Center" Foreground="#FFD699" FontSize="12">
                    <Run FontWeight="SemiBold">Windowed Mode</Run>
                    <Run> - Reduced accuracy. Full-screen recommended.</Run>
                </TextBlock>
            </Border>

            <!-- Main Measurement Area -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Color Patch Display. Shares the positioning patch's drag offset so the
                     measured patch appears exactly where the probe was placed. -->
                <Viewbox Grid.Row="0" Stretch="None" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Viewbox.RenderTransform>
                        <TranslateTransform x:Name="MeasurementPatchTransform"/>
                    </Viewbox.RenderTransform>
                    <Border x:Name="ColorPatchBorder" Width="250" Height="250"
                            Background="White" BorderThickness="0">
                        <!-- Patch color is set programmatically -->
                    </Border>
                </Viewbox>

                <!-- Progress Overlay -->
                <Border Grid.Row="1" Background="#CC1A1A1A" Padding="20,16">
                    <Grid MaxWidth="600">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Progress Bar -->
                        <Grid Grid.Row="0" Margin="0,0,0,8">
                            <ProgressBar Style="{StaticResource CalibrationProgressBar}"
                                         Minimum="0" Maximum="100" Value="{Binding ProgressPercent, Mode=OneWay}"/>
                            <TextBlock Text="{Binding ProgressPercentText}" HorizontalAlignment="Center"
                                       VerticalAlignment="Center" FontWeight="Bold" FontSize="11"/>
                        </Grid>

                        <!-- Patch Info -->
                        <Grid Grid.Row="1" Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding PatchInfoText}"
                                       HorizontalAlignment="Left" Foreground="{StaticResource TextDim}"/>
                            <TextBlock Text="{Binding PhaseText}" Grid.Column="1"
                                       HorizontalAlignment="Center" FontWeight="Medium"/>
                            <TextBlock Text="{Binding TimeInfoText}"
                                       Grid.Column="2" HorizontalAlignment="Right" Foreground="{StaticResource TextDim}"/>
                        </Grid>

                        <!-- Current/Next Patch -->
                        <Grid Grid.Row="2" Margin="0,4,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Current: " Foreground="{StaticResource TextDim}" FontSize="12"/>
                                <TextBlock Text="{Binding CurrentPatchText}" FontSize="12"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="Next: " Foreground="{StaticResource TextDim}" FontSize="12"/>
                                <TextBlock Text="{Binding NextPatchText}" FontSize="12"/>
                            </StackPanel>
                        </Grid>

                        <!-- Control Buttons -->
                        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="{Binding PauseButtonText}" IsEnabled="{Binding IsPauseEnabled}"
                                    Style="{StaticResource SubtleButton}"
                                    Click="Pause_Click" Margin="0,0,8,0"/>
                            <Button Content="Cancel" Style="{StaticResource SubtleButton}"
                                    IsEnabled="{Binding IsCancelEnabled}"
                                    Click="CancelMeasurement_Click" Margin="0,0,8,0"/>
                            <Button Content="{Binding MuteButtonText}" Style="{StaticResource SubtleButton}"
                                    Click="Mute_Click" ToolTip="Mute or unmute capture and completion sounds"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- Pause Overlay -->
            <Grid Background="#CC1A1A1A" Visibility="{Binding IsPauseOverlayVisible, Converter={StaticResource BoolToVis}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Calibration Paused" FontSize="24" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding ResumeCountdownText}"
                               Foreground="{StaticResource TextDim}" HorizontalAlignment="Center" Margin="0,8,0,24"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="Resume" Style="{StaticResource ModernButton}"
                                IsEnabled="{Binding IsCancelEnabled}"
                                Click="Resume_Click" Margin="0,0,8,0"/>
                        <Button Content="Cancel" Style="{StaticResource SubtleButton}"
                                IsEnabled="{Binding IsCancelEnabled}"
                                Click="CancelMeasurement_Click"/>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <!-- Completion Overlay -->
            <Grid Background="#CC1A1A1A" Visibility="{Binding IsCompletionVisible, Converter={StaticResource BoolToVis}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="500">
                    <TextBlock Text="{Binding CompletionIcon}" FontSize="64"
                               Foreground="{Binding CompletionIconBrush}" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                    <TextBlock Text="{Binding CompletionTitle}"
                               FontSize="24" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding CompletionMessage}"
                               Foreground="{StaticResource TextDim}" HorizontalAlignment="Center" Margin="0,8,0,0" TextWrapping="Wrap" TextAlignment="Center"/>

                    <!-- Display Mode Options (only shown when bypass was applied) -->
                    <Border Background="{StaticResource CardBackground}"
                            BorderBrush="{StaticResource CardBorder}" BorderThickness="1"
                            CornerRadius="4" Padding="16" Margin="0,20,0,0"
                            Visibility="{Binding ShowDisplayModeOptions, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Text="Display Preview Mode" FontWeight="SemiBold" Margin="0,0,0,12"/>
                            <RadioButton Style="{StaticResource ModernRadioButton}"
                                         GroupName="DisplayMode" IsChecked="{Binding IsViewCalibrationOnly}"
                                         Checked="DisplayModeOption_Changed">
                                <StackPanel>
                                    <TextBlock Text="Calibration Only" FontWeight="Medium"/>
                                    <TextBlock Text="View display with only the new calibration LUT applied"
                                               Foreground="{StaticResource TextDim}" FontSize="12" TextWrapping="Wrap"/>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton Style="{StaticResource ModernRadioButton}"
                                         GroupName="DisplayMode" IsChecked="{Binding IsViewWithPreviousSettings}"
                                         Checked="DisplayModeOption_Changed">
                                <StackPanel>
                                    <TextBlock Text="Calibration + Previous Settings" FontWeight="Medium"/>
                                    <TextBlock Text="View with calibration, gamma adjustments, and night mode restored"
                                               Foreground="{StaticResource TextDim}" FontSize="12" TextWrapping="Wrap"/>
                                </StackPanel>
                            </RadioButton>
                        </StackPanel>
                    </Border>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,24,0,0">
                        <Button Content="View Report" Style="{StaticResource ModernButton}"
                                Click="ViewReport_Click" Margin="0,0,8,0"
                                Visibility="{Binding IsViewReportVisible, Converter={StaticResource BoolToVis}}"/>
                        <Button Content="Close" Style="{StaticResource SubtleButton}"
                                Click="Close_Click"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
    </Border>
</Window>
