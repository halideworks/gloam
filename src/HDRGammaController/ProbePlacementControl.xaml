<UserControl x:Class="HDRGammaController.ProbePlacementControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="True"
             PreviewKeyDown="Control_PreviewKeyDown">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Gloam;component/Themes/Brutalist.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid x:Name="PlacementSurface"
          Background="#171C23"
          Cursor="SizeAll"
          MouseLeftButtonDown="Surface_MouseLeftButtonDown"
          MouseMove="Surface_MouseMove"
          MouseLeftButtonUp="Surface_MouseLeftButtonUp">
        <Border x:Name="WindowedBanner"
                Background="#3A2A10"
                VerticalAlignment="Top"
                Padding="8,6"
                Panel.ZIndex="100"
                Visibility="Collapsed">
            <TextBlock HorizontalAlignment="Center" Foreground="#FFD699" FontSize="12">
                <Run FontWeight="SemiBold">Windowed Mode</Run>
                <Run> - Drag anywhere to position, resize window to scale patch</Run>
            </TextBlock>
        </Border>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Viewbox Grid.Row="0"
                     Stretch="Uniform"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     Margin="20">
                <Viewbox.RenderTransform>
                    <TranslateTransform x:Name="PatchTransform"/>
                </Viewbox.RenderTransform>
                <Border x:Name="PatchBorder"
                        Width="400"
                        Height="400"
                        Background="White"
                        BorderThickness="0">
                    <Grid>
                        <Ellipse Width="150" Height="150" Stroke="#9AA0A6" StrokeThickness="2"
                                 StrokeDashArray="4 3" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Ellipse Width="92" Height="92" Stroke="#7A7F85" StrokeThickness="2"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Rectangle Width="2" Height="44" Fill="#7A7F85"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Rectangle Width="44" Height="2" Fill="#7A7F85"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Ellipse Width="8" Height="8" Fill="#5F6368"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </Viewbox>

            <Border Grid.Row="1" Background="#EC171C23" Padding="24,20">
                <StackPanel MaxWidth="620" HorizontalAlignment="Center">
                    <TextBlock x:Name="OperationLabel"
                               Foreground="#D76A5F"
                               FontFamily="{DynamicResource DisplayFont}"
                               FontSize="11"
                               FontWeight="Bold"
                               TextAlignment="Center"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"
                               Visibility="Collapsed"/>
                    <TextBlock Text="Position Your Colorimeter"
                               Foreground="White"
                               FontSize="18"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,12"/>
                    <TextBlock TextWrapping="Wrap"
                               Foreground="#A8B0BC"
                               FontSize="13"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               Margin="0,0,0,16">
                        Hang the colorimeter with its counterweight over the top of the
                        display, then <Run Foreground="White" FontWeight="SemiBold">drag the target</Run> (or use the
                        <Run Foreground="White" FontWeight="SemiBold">arrow keys</Run>) so the crosshair sits directly
                        under the sensor, flush against the screen. Click Begin Measurement once it is aligned.
                    </TextBlock>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button x:Name="SecondaryButton"
                                Content="Back"
                                Style="{StaticResource BrutBtnSecondary}"
                                Click="SecondaryButton_Click"
                                Margin="0,0,12,0"
                                Padding="20,10"/>
                        <Button Content="Begin Measurement"
                                Style="{StaticResource BrutBtnPrimary}"
                                Click="BeginButton_Click"
                                Padding="24,10"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
