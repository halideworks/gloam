<UserControl x:Class="HDRGammaController.BrandMark"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--
        The Gloam brand mark: a signal-red disc cut by a diagonal S-curve (matches app.ico
        and the site favicon). The S is drawn in GapBrush over the disc, so set GapBrush to
        whatever sits behind the mark (the title-bar surface) for the cut to read as transparent.
    -->
    <Viewbox Stretch="Uniform">
        <Grid Width="100" Height="100">
            <Ellipse Width="90" Height="90" Margin="5" Fill="{DynamicResource ThemeAccent}"/>
            <Path Data="M15,85 C51.06,74.40 48.94,25.60 85,15"
                  StrokeThickness="13" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                  Stroke="{Binding GapBrush, RelativeSource={RelativeSource AncestorType=UserControl}}">
                <Path.Clip>
                    <EllipseGeometry Center="50,50" RadiusX="45" RadiusY="45"/>
                </Path.Clip>
            </Path>
        </Grid>
    </Viewbox>
</UserControl>
