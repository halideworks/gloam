<Window x:Class="HDRGammaController.DriverInstallDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:HDRGammaController"
        Title="Install USB Drivers"
        Height="360" Width="500"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        Foreground="{DynamicResource ThemeText}"
        FontFamily="{DynamicResource BodyFont}"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Gloam;component/Themes/Brutalist.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <SolidColorBrush x:Key="SuccessBrush" Color="#22C55E"/>
            <SolidColorBrush x:Key="WarningBrush" Color="#F59E0B"/>
            <SolidColorBrush x:Key="ErrorBrush" Color="#EF4444"/>
        </ResourceDictionary>
    </Window.Resources>

    <Border Background="{DynamicResource ThemeBg}" BorderBrush="{DynamicResource ThemeWindowFrame}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="42"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" Background="{DynamicResource ThemeSurface}"
                    BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid Margin="16,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <local:BrandMark Width="20" Height="20" Margin="0,0,10,0" VerticalAlignment="Center" GapBrush="{DynamicResource ThemeSurface}"/>
                        <TextBlock Text="USB driver required" FontFamily="{DynamicResource DisplayFont}"
                                   FontWeight="Bold" FontSize="13" Foreground="{DynamicResource ThemeText}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content -->
            <Grid Grid.Row="1" Margin="24,20">
                <!-- Initial explanation -->
                <StackPanel x:Name="ExplanationPanel" Visibility="Visible">
                    <TextBlock Text="Your colorimeter needs a special USB driver to communicate with calibration software."
                               TextWrapping="Wrap" Margin="0,0,0,16" LineHeight="20"/>

                    <Border Background="{DynamicResource ThemeSurface}" BorderBrush="{DynamicResource ThemeBorder}"
                            BorderThickness="1" Padding="12" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="What happens next:" FontWeight="Bold" Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                <TextBlock Text="1." FontWeight="Bold" Width="20" Foreground="{DynamicResource ThemeAccent}"/>
                                <TextBlock Text="Click 'Install Drivers' below" TextWrapping="Wrap"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                <TextBlock Text="2." FontWeight="Bold" Width="20" Foreground="{DynamicResource ThemeAccent}"/>
                                <TextBlock Text="A driver installer window will open (requires admin)" TextWrapping="Wrap"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                <TextBlock Text="3." FontWeight="Bold" Width="20" Foreground="{DynamicResource ThemeAccent}"/>
                                <TextBlock Text="Select your colorimeter from the list and click Install" TextWrapping="Wrap"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                <TextBlock Text="4." FontWeight="Bold" Width="20" Foreground="{DynamicResource ThemeAccent}"/>
                                <TextBlock Text="Close the installer when done" TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Background="Transparent" BorderBrush="{StaticResource WarningBrush}" BorderThickness="1"
                            Padding="10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="!" FontWeight="Bold" Foreground="{StaticResource WarningBrush}" FontSize="16" Margin="0,0,8,0"/>
                            <TextBlock Text="Note: X-Rite's own software (i1Profiler) may stop working after this. You can uninstall the ArgyllCMS driver later to restore it."
                                       TextWrapping="Wrap" Foreground="{StaticResource WarningBrush}" FontSize="11"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Installing state -->
                <StackPanel x:Name="InstallingPanel" Visibility="Collapsed" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="Waiting for driver installer..." FontWeight="Bold" FontSize="16" HorizontalAlignment="Center"/>
                    <TextBlock Text="Complete the installation in the ArgyllCMS window"
                               Foreground="{DynamicResource ThemeTextDim}" FontSize="12" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>

                <!-- Result view -->
                <StackPanel x:Name="ResultPanel" Visibility="Collapsed" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock x:Name="ResultIcon" Text="OK" FontSize="32" FontWeight="Bold"
                               FontFamily="{DynamicResource DisplayFont}" HorizontalAlignment="Center"
                               Foreground="{StaticResource SuccessBrush}" Margin="0,0,0,12"/>
                    <TextBlock x:Name="ResultText" Text="Driver installation complete!" FontWeight="Bold" FontSize="16"
                               HorizontalAlignment="Center" TextAlignment="Center"/>
                    <TextBlock x:Name="ResultDetailText" Text="Click 'Retry Calibration' to continue"
                               Foreground="{DynamicResource ThemeTextDim}" FontSize="12" HorizontalAlignment="Center"
                               Margin="0,8,0,0" TextWrapping="Wrap" TextAlignment="Center"/>
                </StackPanel>
            </Grid>

            <!-- Footer Buttons -->
            <Border Grid.Row="2" Background="{DynamicResource ThemeSurface}"
                    BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="0,1,0,0" Padding="24,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Initial buttons -->
                    <StackPanel x:Name="InitialButtons" Grid.Column="1" Orientation="Horizontal" Grid.ColumnSpan="2">
                        <Button Content="Cancel" Click="Cancel_Click" Margin="0,0,12,0"/>
                        <Button x:Name="InstallButton" Content="Install Drivers" Style="{StaticResource BrutBtnPrimary}" Click="Install_Click"/>
                    </StackPanel>

                    <!-- Result buttons -->
                    <StackPanel x:Name="ResultButtons" Grid.Column="1" Orientation="Horizontal" Grid.ColumnSpan="2" Visibility="Collapsed">
                        <Button x:Name="CloseButton" Content="Close" Click="Close_Click" Margin="0,0,12,0"/>
                        <Button x:Name="RetryButton" Content="Retry Calibration" Style="{StaticResource BrutBtnPrimary}" Click="Retry_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
