<Window x:Class="HDRGammaController.DriverInstallDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Install USB Drivers"
        Height="340" Width="500"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E"
        Foreground="White"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Window.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#0078D4"/>
        <SolidColorBrush x:Key="CardBackground" Color="#2D2D2D"/>
        <SolidColorBrush x:Key="CardBorder" Color="#3F3F3F"/>
        <SolidColorBrush x:Key="TextDim" Color="#888888"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#22C55E"/>
        <SolidColorBrush x:Key="WarningBrush" Color="#F59E0B"/>
        <SolidColorBrush x:Key="ErrorBrush" Color="#EF4444"/>

        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#1E1E1E" BorderBrush="#3F3F3F" BorderThickness="1" CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" Background="#252525" CornerRadius="8,8,0,0" MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid Margin="16,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="USB Driver Required" FontWeight="Medium" FontSize="14"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content -->
            <Grid Grid.Row="1" Margin="24,20">
                <!-- Initial explanation -->
                <StackPanel x:Name="ExplanationPanel" Visibility="Visible">
                    <TextBlock Text="Your colorimeter needs a special USB driver to communicate with calibration software."
                               TextWrapping="Wrap" Margin="0,0,0,16" LineHeight="20"/>

                    <Border Background="{StaticResource CardBackground}" CornerRadius="6" Padding="12" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="What happens next:" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                <TextBlock Text="1." FontWeight="Bold" Width="20"/>
                                <TextBlock Text="Click 'Install Drivers' below" TextWrapping="Wrap"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                <TextBlock Text="2." FontWeight="Bold" Width="20"/>
                                <TextBlock Text="A driver installer window will open (requires admin)" TextWrapping="Wrap"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                <TextBlock Text="3." FontWeight="Bold" Width="20"/>
                                <TextBlock Text="Select your colorimeter from the list and click Install" TextWrapping="Wrap"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                <TextBlock Text="4." FontWeight="Bold" Width="20"/>
                                <TextBlock Text="Close the installer when done" TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Background="#3D2D1D" BorderBrush="{StaticResource WarningBrush}" BorderThickness="1"
                            CornerRadius="4" Padding="10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="!" FontWeight="Bold" Foreground="{StaticResource WarningBrush}" FontSize="16" Margin="0,0,8,0"/>
                            <TextBlock Text="Note: X-Rite's own software (i1Profiler) may stop working after this. You can uninstall the ArgyllCMS driver later to restore it."
                                       TextWrapping="Wrap" Foreground="{StaticResource WarningBrush}" FontSize="11"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Installing state -->
                <StackPanel x:Name="InstallingPanel" Visibility="Collapsed" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="Waiting for driver installer..." FontWeight="Medium" FontSize="16" HorizontalAlignment="Center"/>
                    <TextBlock Text="Complete the installation in the ArgyllCMS window"
                               Foreground="{StaticResource TextDim}" FontSize="12" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>

                <!-- Result view -->
                <StackPanel x:Name="ResultPanel" Visibility="Collapsed" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock x:Name="ResultIcon" Text="✓" FontSize="48" HorizontalAlignment="Center"
                               Foreground="{StaticResource SuccessBrush}" Margin="0,0,0,12"/>
                    <TextBlock x:Name="ResultText" Text="Driver installation complete!" FontWeight="Medium" FontSize="16"
                               HorizontalAlignment="Center" TextAlignment="Center"/>
                    <TextBlock x:Name="ResultDetailText" Text="Click 'Retry Calibration' to continue"
                               Foreground="{StaticResource TextDim}" FontSize="12" HorizontalAlignment="Center"
                               Margin="0,8,0,0" TextWrapping="Wrap" TextAlignment="Center"/>
                </StackPanel>
            </Grid>

            <!-- Footer Buttons -->
            <Border Grid.Row="2" Background="#252525" CornerRadius="0,0,8,8" Padding="24,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Initial buttons -->
                    <StackPanel x:Name="InitialButtons" Grid.Column="1" Orientation="Horizontal" Grid.ColumnSpan="2">
                        <Button Content="Cancel" Background="#444" Click="Cancel_Click" Margin="0,0,12,0"/>
                        <Button x:Name="InstallButton" Content="Install Drivers" Click="Install_Click"/>
                    </StackPanel>

                    <!-- Result buttons -->
                    <StackPanel x:Name="ResultButtons" Grid.Column="1" Orientation="Horizontal" Grid.ColumnSpan="2" Visibility="Collapsed">
                        <Button x:Name="CloseButton" Content="Close" Background="#444" Click="Close_Click" Margin="0,0,12,0"/>
                        <Button x:Name="RetryButton" Content="Retry Calibration" Click="Retry_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
