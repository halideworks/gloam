<Window x:Class="HDRGammaController.ArgyllDownloadDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:HDRGammaController"
        Title="ArgyllCMS Download"
        Height="280" Width="450"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        Foreground="{DynamicResource ThemeText}"
        FontFamily="{DynamicResource BodyFont}"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Gloam;component/Themes/Brutalist.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <SolidColorBrush x:Key="SuccessBrush" Color="#22C55E"/>
            <SolidColorBrush x:Key="ErrorBrush" Color="#EF4444"/>
        </ResourceDictionary>
    </Window.Resources>

    <Border Background="{DynamicResource ThemeBg}" BorderBrush="{DynamicResource ThemeWindowFrame}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="42"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" Background="{DynamicResource ThemeSurface}"
                    BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid Margin="16,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <local:BrandMark Width="20" Height="20" Margin="0,0,10,0" VerticalAlignment="Center" GapBrush="{DynamicResource ThemeSurface}"/>
                        <TextBlock Text="Download ArgyllCMS" FontFamily="{DynamicResource DisplayFont}"
                                   FontWeight="Bold" FontSize="13" Foreground="{DynamicResource ThemeText}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content -->
            <Grid Grid.Row="1" Margin="24,20">
                <!-- Confirmation View -->
                <StackPanel x:Name="ConfirmationPanel" Visibility="Visible">
                    <TextBlock x:Name="ReasonText" Text="" TextWrapping="Wrap" Margin="0,0,0,16" LineHeight="20"/>
                    <TextBlock Text="Would you like to download ArgyllCMS automatically?" FontWeight="Bold" Margin="0,0,0,8"/>
                    <TextBlock Foreground="{DynamicResource ThemeTextDim}" FontSize="12" TextWrapping="Wrap">
                        This will download approximately 15MB from argyllcms.com and install to your local AppData folder.
                    </TextBlock>
                </StackPanel>

                <!-- Progress View -->
                <StackPanel x:Name="ProgressPanel" Visibility="Collapsed" VerticalAlignment="Center">
                    <TextBlock x:Name="ProgressStatusText" Text="Downloading..." FontWeight="Bold" Margin="0,0,0,12"/>
                    <Grid Margin="0,0,0,8">
                        <Border Background="{DynamicResource ThemeTrack}" Height="6"/>
                        <Border x:Name="ProgressBar" Background="{DynamicResource ThemeMeter}"
                                Height="6" HorizontalAlignment="Left" Width="0"/>
                    </Grid>
                    <TextBlock x:Name="ProgressDetailText" Text="" Foreground="{DynamicResource ThemeTextDim}" FontSize="12"/>
                </StackPanel>

                <!-- Result View -->
                <StackPanel x:Name="ResultPanel" Visibility="Collapsed" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock x:Name="ResultIcon" Text="OK" FontSize="32" FontWeight="Bold"
                               FontFamily="{DynamicResource DisplayFont}" HorizontalAlignment="Center"
                               Foreground="{StaticResource SuccessBrush}" Margin="0,0,0,12"/>
                    <TextBlock x:Name="ResultText" Text="Download complete!" FontWeight="Bold" FontSize="16"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="ResultDetailText" Text="" Foreground="{DynamicResource ThemeTextDim}"
                               FontSize="12" HorizontalAlignment="Center" Margin="0,8,0,0" TextWrapping="Wrap"
                               TextAlignment="Center"/>
                </StackPanel>
            </Grid>

            <!-- Footer Buttons -->
            <Border Grid.Row="2" Background="{DynamicResource ThemeSurface}"
                    BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="0,1,0,0" Padding="24,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Confirmation buttons -->
                    <StackPanel x:Name="ConfirmationButtons" Grid.Column="1" Orientation="Horizontal" Grid.ColumnSpan="2">
                        <Button Content="No, Thanks" Click="Cancel_Click" Margin="0,0,12,0"/>
                        <Button x:Name="YesButton" Content="Yes, Download" Style="{StaticResource BrutBtnPrimary}" Click="Yes_Click"/>
                    </StackPanel>

                    <!-- Progress cancel button -->
                    <Button x:Name="CancelDownloadButton" Grid.Column="2" Content="Cancel"
                            Click="CancelDownload_Click" Visibility="Collapsed"/>

                    <!-- Result close button -->
                    <Button x:Name="CloseButton" Grid.Column="2" Content="Close"
                            Click="Close_Click" Visibility="Collapsed"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
