<Window x:Class="HDRGammaController.GameLabWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:HDRGammaController"
        Title="Gloam - Game Lab"
        Width="1040" Height="660"
        MinWidth="940" MinHeight="640"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        Foreground="{DynamicResource ThemeText}"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="True"
        Topmost="False">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Gloam;component/Themes/Brutalist.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>

            <Style x:Key="GameLibraryRow" TargetType="ListBoxItem">
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Margin" Value="0,0,0,4"/>
                <Setter Property="Foreground" Value="{DynamicResource ThemeText}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListBoxItem">
                            <Border x:Name="Row" BorderBrush="{DynamicResource ThemeBorder}"
                                    BorderThickness="1" Background="{DynamicResource ThemeBg}"
                                    Padding="9,7" Cursor="Hand" SnapsToDevicePixels="True">
                                <ContentPresenter/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="Row" Property="BorderBrush" Value="{DynamicResource ThemeAccent}"/>
                                    <Setter TargetName="Row" Property="BorderThickness" Value="3,1,1,1"/>
                                    <Setter TargetName="Row" Property="Padding" Value="7,7,9,7"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Row" Property="Background" Value="{DynamicResource ThemeHover}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="QuickLookRow" TargetType="ListBoxItem">
                <Setter Property="Margin" Value="0,0,7,0"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListBoxItem">
                            <Border x:Name="Card" BorderBrush="{DynamicResource ThemeBorder}"
                                    BorderThickness="1" Background="{DynamicResource ThemeBg}"
                                    Padding="9,7" Cursor="Hand">
                                <ContentPresenter/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="Card" Property="BorderBrush" Value="{DynamicResource ThemeAccent}"/>
                                    <Setter TargetName="Card" Property="BorderThickness" Value="2"/>
                                    <Setter TargetName="Card" Property="Padding" Value="8,6"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Card" Property="Background" Value="{DynamicResource ThemeHover}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Border Background="{DynamicResource ThemeBg}"
            BorderBrush="{DynamicResource ThemeWindowFrame}" BorderThickness="1">
        <Grid x:Name="GameLabViewport">
            <Grid.RowDefinitions>
                <RowDefinition Height="46"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{DynamicResource ThemeSurface}"
                    BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid Margin="15,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <local:BrandMark Width="19" Height="19" Margin="0,0,9,0"
                                         GapBrush="{DynamicResource ThemeSurface}"/>
                        <TextBlock Text="GLOAM" FontFamily="{StaticResource DisplayFont}"
                                   FontWeight="ExtraBold" FontSize="15"
                                   Foreground="{DynamicResource ThemeText}" VerticalAlignment="Center"/>
                        <Border Width="1" Height="15" Background="{DynamicResource ThemeTextDim}"
                                Opacity="0.5" Margin="11,0"/>
                        <TextBlock Text="Game Lab" FontFamily="{StaticResource DisplayFont}"
                                   FontWeight="Bold" FontSize="12"
                                   Foreground="{DynamicResource ThemeTextDim}" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding AppVersion}" FontFamily="{StaticResource DisplayFont}"
                                   FontSize="10" Foreground="{DynamicResource ThemeTextDim}" Opacity="0.7"
                                   VerticalAlignment="Center" Margin="9,0,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock Text="Win + Shift + G" FontFamily="{StaticResource MonoFont}" FontSize="10"
                                   Foreground="{DynamicResource ThemeTextDim}" VerticalAlignment="Center" Margin="0,0,9,0"/>
                        <Button x:Name="ThemeToggleButton" Content="&#x25D0;" Width="30" Height="30"
                                Style="{StaticResource BrutIconButton}" FontSize="15"
                                ToolTip="Toggle light / dark" Click="ThemeToggle_Click"/>
                        <Button Content="&#x2715;" Width="30" Height="30"
                                Style="{StaticResource BrutIconButton}" FontSize="13"
                                ToolTip="Close Game Lab" Click="Close_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- The dedicated surface has no window-level ScrollViewer. Library and scan
                 lists virtualize independently, so 100+ games never create 100+ editors. -->
            <Grid Grid.Row="1" Margin="18,16,18,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{DynamicResource ThemeSurface}"
                        BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1"
                        Padding="12,9" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="265"/>
                            <ColumnDefinition Width="1"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="225"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding GamerModeStateTitle}" Style="{StaticResource Kicker}"/>
                            <TextBlock Text="{Binding GamerModeStateDetails}" FontSize="9"
                                       Foreground="{DynamicResource ThemeTextDim}" Margin="0,3,0,0"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                        <Border Grid.Column="1" Background="{DynamicResource ThemeBorder}" Margin="0,1,14,1"/>
                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <TextBlock Text="CURRENT GAME" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Text="{Binding GamerMode.ActiveSessionSummary}"
                                       FontFamily="{StaticResource DisplayFont}" FontWeight="Bold" FontSize="13"
                                       Foreground="{DynamicResource ThemeText}" Margin="0,2,0,0"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding GamerMode.ActiveSessionDetails}" FontSize="9"
                                       Foreground="{DynamicResource ThemeTextDim}"
                                       TextTrimming="CharacterEllipsis" MaxHeight="14"/>
                        </StackPanel>
                        <Grid Grid.Column="3" Margin="12,0,0,0" VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid>
                                <ComboBox x:Name="GameLabLibraryPresetPicker" Height="30" Margin="0"
                                          ItemsSource="{Binding GamerMode.AvailableLibraryPresets}"
                                          SelectedItem="{Binding GamerMode.SelectedLibraryPreset, Mode=TwoWay}"
                                          ToolTip="Set one look for the library, including a detected-HDR-only option"/>
                                <TextBlock Text="Library default…" Margin="9,0,28,0" VerticalAlignment="Center"
                                           IsHitTestVisible="False" Foreground="{DynamicResource ThemeTextDim}" FontSize="9">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding GamerMode.HasSelectedLibraryPreset}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                            <Button Grid.Column="1" Content="Apply" Margin="6,0,0,0" Padding="9,6"
                                    Command="{Binding ApplyGamerLibraryPresetCommand}"
                                    IsEnabled="{Binding GamerMode.HasSelectedLibraryPreset}"/>
                        </Grid>
                        <Button Grid.Column="4" Content="{Binding GamerModeToggleLabel}"
                                Command="{Binding ToggleGamerModeCommand}"
                                Style="{StaticResource BrutBtnPrimary}" Margin="15,0,0,0"
                                VerticalAlignment="Center" Padding="15,8"
                                AutomationProperties.AutomationId="ToggleGamerMode"/>
                    </Grid>
                </Border>

                <!-- Normal library + single selected editor. -->
                <Grid Grid.Row="1" x:Name="LibraryWorkspace">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding GamerMode.HasDiscoveryResults}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="258"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1"
                            Background="{DynamicResource ThemeSurface}" Padding="10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid Margin="2,0,0,7">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="YOUR GAMES" Style="{StaticResource Kicker}"/>
                                    <TextBlock Text="{Binding GamerMode.FilteredProfileCountText}"
                                               Style="{StaticResource FieldLabel}" Margin="0,2,0,0"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="{Binding GamerMode.ShowAllProfilesLabel}"
                                        Command="{Binding ToggleShowAllGamerProfilesCommand}"
                                        Style="{StaticResource BrutIconButton}" HorizontalAlignment="Right"
                                        VerticalAlignment="Center" Padding="6,3" FontSize="9" Margin="6,0,0,0"/>
                            </Grid>
                            <Grid Grid.Row="1" Margin="0,0,0,8">
                                <TextBox x:Name="GameProfileSearchBox"
                                         Text="{Binding GamerMode.ProfileSearchText, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Search game names or executables"
                                         AutomationProperties.Name="Search your game library"/>
                                <TextBlock Text="Search games or executables" Margin="9,0"
                                           VerticalAlignment="Center" IsHitTestVisible="False"
                                           Foreground="{DynamicResource ThemeTextDim}" FontSize="10">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding GamerMode.ProfileSearchText}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding GamerMode.ProfileSearchText}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                            <ListBox Grid.Row="2" x:Name="GameProfileList"
                                     ItemsSource="{Binding GamerMode.FilteredProfiles}"
                                     SelectedItem="{Binding GamerMode.SelectedProfile, Mode=TwoWay}"
                                     Background="Transparent" BorderThickness="0"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.CanContentScroll="True"
                                     VirtualizingPanel.IsVirtualizing="True"
                                     VirtualizingPanel.VirtualizationMode="Recycling"
                                     VirtualizingPanel.ScrollUnit="Pixel"
                                     ItemContainerStyle="{StaticResource GameLibraryRow}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding GameTitle}" ToolTip="{Binding GameTitle}"
                                                           FontFamily="{StaticResource DisplayFont}"
                                                           FontWeight="Bold" FontSize="11" TextTrimming="CharacterEllipsis"
                                                           Foreground="{DynamicResource ThemeText}"/>
                                                <TextBlock Text="{Binding AppName}" ToolTip="{Binding AppName}"
                                                           FontFamily="{StaticResource MonoFont}"
                                                           FontSize="9" TextTrimming="CharacterEllipsis"
                                                           Foreground="{DynamicResource ThemeTextDim}"/>
                                            </StackPanel>
                                            <Border Grid.Column="1" Width="6" Height="6" CornerRadius="3"
                                                    VerticalAlignment="Center" Margin="8,0,1,0">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{DynamicResource ThemeBorder}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Enabled}" Value="True">
                                                                <Setter Property="Background" Value="{DynamicResource ThemeAccent}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <TextBlock Grid.Row="3" Text="ADD A RUNNING GAME" Style="{StaticResource FieldLabel}"
                                       Margin="2,8,0,5"/>
                            <Grid Grid.Row="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox x:Name="GamerAppPicker" IsEditable="True"
                                          ItemsSource="{Binding GamerMode.RunningApps}"
                                          Text="{Binding GamerMode.NewAppText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          ToolTip="Choose a running game or type a full executable path"
                                          AutomationProperties.AutomationId="GamerAppPicker"/>
                                <TextBlock Text="Choose a running game" Margin="9,0"
                                           VerticalAlignment="Center" IsHitTestVisible="False"
                                           Foreground="{DynamicResource ThemeTextDim}" FontSize="10">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding GamerMode.NewAppText}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding GamerMode.NewAppText}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <Button x:Name="AddGamerProfileButton" Grid.Column="1" Content="Add"
                                        Command="{Binding AddGamerProfileCommand}" Padding="11,7"
                                        AutomationProperties.AutomationId="AddGamerProfile"/>
                            </Grid>

                            <StackPanel Grid.Row="5" Margin="0,8,0,0">
                                <Button Content="Find installed games" Command="{Binding ScanForGamesCommand}"
                                        AutomationProperties.AutomationId="ScanForGames">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource BrutBtnSecondary}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding GamerMode.IsScanningForGames}" Value="True">
                                                    <Setter Property="IsEnabled" Value="False"/>
                                                    <Setter Property="Content" Value="Scanning launcher libraries…"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <TextBlock Text="{Binding GamerMode.DiscoveryStatus}" FontSize="9"
                                           Foreground="{DynamicResource ThemeTextDim}" TextWrapping="Wrap"
                                           MaxHeight="27" Margin="2,5,2,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2" BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1"
                            Background="{DynamicResource ThemeSurface}" Padding="14">
                        <Grid>
                            <Border HorizontalAlignment="Center" VerticalAlignment="Center" Padding="24">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding GamerMode.HasProfiles}" Value="False">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <TextBlock Text="No games yet" FontFamily="{StaticResource DisplayFont}"
                                               FontWeight="ExtraBold" FontSize="20" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Find installed games or add the game currently running."
                                               Foreground="{DynamicResource ThemeTextDim}" FontSize="11"
                                               Margin="0,5,0,0" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <ContentControl Content="{Binding GamerMode.SelectedProfile}">
                                <ContentControl.ContentTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <Grid Grid.Row="0" Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding GameTitle}" FontFamily="{StaticResource DisplayFont}"
                                                               FontSize="18" FontWeight="ExtraBold" TextTrimming="CharacterEllipsis"
                                                               Foreground="{DynamicResource ThemeText}"/>
                                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                        <TextBlock Text="{Binding AppName}" FontFamily="{StaticResource MonoFont}"
                                                                   FontSize="9" Foreground="{DynamicResource ThemeTextDim}"
                                                                   TextTrimming="CharacterEllipsis" ToolTip="{Binding ExecutablePath}"/>
                                                        <TextBlock Text="  ·  " FontSize="9" Foreground="{DynamicResource ThemeTextDim}"/>
                                                        <TextBlock Text="{Binding ExecutableIdentityLabel}" FontSize="9">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="{DynamicResource ThemeAccent}"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding HasExecutablePath}" Value="False">
                                                                            <Setter Property="Foreground" Value="{DynamicResource ThemeAmber}"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        <TextBlock Text="  ·  " FontSize="9" Foreground="{DynamicResource ThemeTextDim}"/>
                                                        <TextBlock Text="{Binding HdrSupportLabel}" FontSize="9">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="{DynamicResource ThemeTextDim}"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsHdrCapable}" Value="True">
                                                                            <Setter Property="Foreground" Value="{DynamicResource ThemeAccent}"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </StackPanel>
                                                <CheckBox Grid.Column="1" Content="Auto-apply"
                                                          IsChecked="{Binding Enabled, Mode=TwoWay}"
                                                          VerticalAlignment="Center" Margin="12,0"/>
                                                <Button Grid.Column="2" Content="Remove" Style="{StaticResource BrutIconButton}"
                                                        Command="{Binding DataContext.RemoveGamerProfileCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}" VerticalAlignment="Center"/>
                                            </Grid>

                                            <StackPanel Grid.Row="1">
                                                <TextBlock Text="CHOOSE A LOOK" Style="{StaticResource FieldLabel}" Margin="0,0,0,5"/>
                                                <ListBox ItemsSource="{Binding AvailableQuickLooks}"
                                                         SelectedValuePath="Value"
                                                         SelectedValue="{Binding PictureIntent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                         Background="Transparent" BorderThickness="0" Padding="0"
                                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                         ItemContainerStyle="{StaticResource QuickLookRow}">
                                                    <ListBox.ItemsPanel>
                                                        <ItemsPanelTemplate><UniformGrid Rows="1"/></ItemsPanelTemplate>
                                                    </ListBox.ItemsPanel>
                                                    <ListBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding Label}" FontFamily="{StaticResource DisplayFont}"
                                                                           FontWeight="Bold" FontSize="11"
                                                                           Foreground="{DynamicResource ThemeText}"/>
                                                                <TextBlock Text="{Binding Description}" FontSize="8"
                                                                           Foreground="{DynamicResource ThemeTextDim}" Margin="0,1,0,0"/>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ListBox.ItemTemplate>
                                                </ListBox>
                                                <TextBlock Text="{Binding IntentDescription}" Margin="0,6,0,0"
                                                           Foreground="{DynamicResource ThemeTextDim}" FontSize="10"
                                                           TextWrapping="Wrap" MaxHeight="30"/>
                                            </StackPanel>

                                            <Grid Grid.Row="2" Margin="0,10,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Margin="0,0,14,0">
                                                    <Grid>
                                                        <TextBlock Text="DARK-AREA VISIBILITY" Style="{StaticResource FieldLabel}"/>
                                                        <TextBlock Text="{Binding ShadowDetailPlainLabel}" HorizontalAlignment="Right"
                                                                   FontSize="9" Foreground="{DynamicResource ThemeTextDim}"/>
                                                    </Grid>
                                                    <Slider Minimum="0" Maximum="100" Value="{Binding ShadowDetailPercent}"
                                                            TickFrequency="5" IsSnapToTickEnabled="False"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                                    <CheckBox Content="Keep this look steady while I play"
                                                              IsChecked="{Binding GameplayLock, Mode=TwoWay}"/>
                                                    <TextBlock Text="Prevents scheduled fades until you leave the game."
                                                               Margin="24,2,0,0" FontSize="9"
                                                               Foreground="{DynamicResource ThemeTextDim}"/>
                                                </StackPanel>
                                            </Grid>

                                            <Grid Grid.Row="3" Margin="0,10,0,0"
                                                  Visibility="{Binding IsNightOps, Converter={StaticResource BoolToVis}}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Margin="0,0,14,0">
                                                    <TextBlock Text="NIGHT WARMTH" Style="{StaticResource FieldLabel}"/>
                                                    <Slider Minimum="1900" Maximum="5000" Value="{Binding NightOpsKelvin}"
                                                            TickFrequency="100"/>
                                                    <TextBlock Text="{Binding NightOpsKelvin, StringFormat={}{0} K}" FontSize="9"
                                                               Foreground="{DynamicResource ThemeTextDim}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                                    <TextBlock Text="COLOR SEPARATION" Style="{StaticResource FieldLabel}"/>
                                                    <Slider Minimum="0" Maximum="100" Value="{Binding NightOpsStrengthPercent}"
                                                            TickFrequency="5"/>
                                                    <TextBlock Text="{Binding NightOpsStrengthPercent, StringFormat={}{0:F0}% preservation}" FontSize="9"
                                                               Foreground="{DynamicResource ThemeTextDim}"/>
                                                </StackPanel>
                                            </Grid>

                                            <Expander Grid.Row="4" Header="Advanced signal &amp; display controls"
                                                      Margin="0,9,0,0" Foreground="{DynamicResource ThemeText}"
                                                      IsExpanded="{Binding DataContext.IsGameProfileAdvancedExpanded, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}">
                                                <Grid x:Name="AdvancedControlsGrid" Margin="0,7,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,9,0">
                                                        <TextBlock Text="PROFILE NAME" Style="{StaticResource FieldLabel}"/>
                                                        <TextBox x:Name="AdvancedProfileNameBox"
                                                                 Text="{Binding DisplayName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Row="0" Grid.Column="2" Grid.ColumnSpan="2" Margin="0,0,9,0">
                                                        <TextBlock Text="HDR SUPPORT" Style="{StaticResource FieldLabel}"/>
                                                        <ComboBox x:Name="AdvancedHdrSupportBox"
                                                                  Margin="0"
                                                                  ItemsSource="{Binding AvailableHdrCapabilities}" DisplayMemberPath="Label"
                                                                  SelectedValuePath="Value" SelectedValue="{Binding HdrCapability, Mode=TwoWay}"
                                                                  ToolTip="Detected from local game configuration; you can correct it here"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Row="0" Grid.Column="4" Grid.ColumnSpan="2" Margin="0,0,9,0">
                                                        <TextBlock Text="EXPECTED SIGNAL" Style="{StaticResource FieldLabel}"/>
                                                        <ComboBox x:Name="AdvancedExpectedSignalBox"
                                                                  Margin="0"
                                                                  ItemsSource="{Binding AvailableHdrExpectations}" DisplayMemberPath="Label"
                                                                  SelectedValuePath="Value" SelectedValue="{Binding HdrExpectation, Mode=TwoWay}"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Row="0" Grid.Column="6" Grid.ColumnSpan="2">
                                                        <TextBlock Text="TARGET DISPLAYS" Style="{StaticResource FieldLabel}"/>
                                                        <ComboBox x:Name="AdvancedTargetDisplaysBox"
                                                                  Margin="0"
                                                                  ItemsSource="{Binding AvailableDisplayScopes}" DisplayMemberPath="Label"
                                                                  SelectedValuePath="Value" SelectedValue="{Binding DisplayScope, Mode=TwoWay}"/>
                                                    </StackPanel>

                                                    <ComboBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="8" Margin="0,5,0,0"
                                                              Visibility="{Binding IsSpecificDisplay, Converter={StaticResource BoolToVis}}"
                                                              ItemsSource="{Binding DataContext.GamerMode.AvailableDisplays, RelativeSource={RelativeSource AncestorType=Window}}"
                                                              DisplayMemberPath="Label" SelectedValuePath="DevicePath"
                                                              SelectedValue="{Binding MonitorDevicePath, Mode=TwoWay}"/>

                                                    <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,7,9,0">
                                                        <TextBlock Text="NIGHT BEHAVIOR" Style="{StaticResource FieldLabel}"/>
                                                        <ComboBox x:Name="AdvancedNightBehaviorBox"
                                                                  Margin="0"
                                                                  ItemsSource="{Binding AvailableNightPolicies}" DisplayMemberPath="Label"
                                                                  SelectedValuePath="Value" SelectedValue="{Binding NightPolicy, Mode=TwoWay}"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="2" Margin="0,7,9,0">
                                                        <Grid>
                                                            <TextBlock Text="GAMMA" Style="{StaticResource FieldLabel}"/>
                                                            <CheckBox Content="Override" HorizontalAlignment="Right"
                                                                      VerticalAlignment="Center" Margin="0,-2,0,-2"
                                                                      IsChecked="{Binding OverrideGamma, Mode=TwoWay}"/>
                                                        </Grid>
                                                        <ComboBox x:Name="AdvancedGammaModeBox" Margin="0"
                                                                  IsEnabled="{Binding OverrideGamma}"
                                                                  ItemsSource="{Binding AvailableGammaModes}" DisplayMemberPath="Label"
                                                                  SelectedValuePath="Value" SelectedValue="{Binding GammaMode, Mode=TwoWay}"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Row="2" Grid.Column="4" Grid.ColumnSpan="2" Margin="0,7,9,0">
                                                        <TextBlock Text="PAPER WHITE" Style="{StaticResource FieldLabel}"/>
                                                        <TextBox x:Name="AdvancedPaperWhiteBox"
                                                                 Text="{Binding PaperWhiteNits, UpdateSourceTrigger=PropertyChanged, StringFormat=F0}"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Row="2" Grid.Column="6" Grid.ColumnSpan="2" Margin="0,7,0,0">
                                                        <TextBlock Text="PEAK NITS" Style="{StaticResource FieldLabel}"/>
                                                        <TextBox x:Name="AdvancedPeakNitsBox"
                                                                 Text="{Binding PeakNits, UpdateSourceTrigger=PropertyChanged, StringFormat=F0}"/>
                                                    </StackPanel>

                                                    <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="6" Margin="0,7,9,0"
                                                                VerticalAlignment="Bottom"
                                                                Visibility="{Binding IsNightOps, Converter={StaticResource BoolToVis}}">
                                                        <TextBlock Text="NIGHT PLAY SPECTRAL LIMIT" Style="{StaticResource FieldLabel}"/>
                                                        <CheckBox Content="Use an optional melanopic ceiling"
                                                                  VerticalAlignment="Center"
                                                                  IsChecked="{Binding IsNightOpsMelanopicCeilingEnabled, Mode=TwoWay}"
                                                                  ToolTip="Off by default because a hard ceiling can alter the selected look."/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Row="3" Grid.Column="6" Grid.ColumnSpan="2" Margin="0,7,0,0"
                                                                Visibility="{Binding IsNightOps, Converter={StaticResource BoolToVis}}">
                                                        <TextBlock Text="MELANOPIC CEILING" Style="{StaticResource FieldLabel}"/>
                                                        <TextBox x:Name="AdvancedMelanopicCeilingBox"
                                                                 IsEnabled="{Binding IsNightOpsMelanopicCeilingEnabled}"
                                                                 Text="{Binding NightOpsMelanopicCeiling, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Expander>
                                        </Grid>
                                    </DataTemplate>
                                </ContentControl.ContentTemplate>
                            </ContentControl>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Scan review replaces the workspace instead of growing the window. -->
                <Border Grid.Row="1" x:Name="GameScanPanel"
                        BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1"
                        Background="{DynamicResource ThemeSurface}" Padding="14">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding GamerMode.HasDiscoveryResults}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="REVIEW FOUND GAMES" Style="{StaticResource Kicker}"/>
                                <TextBlock Text="Choose only the games you want Gloam to recognize. Nothing is selected automatically."
                                           FontFamily="{StaticResource DisplayFont}" FontWeight="Bold" FontSize="14"
                                           Foreground="{DynamicResource ThemeText}" Margin="0,3,0,0"/>
                                <TextBlock Text="{Binding GamerMode.DiscoveryStatus}" FontSize="10"
                                           Foreground="{DynamicResource ThemeTextDim}" Margin="0,2,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="Back to library"
                                    Command="{Binding DismissGameDiscoveryCommand}"
                                    VerticalAlignment="Center" Margin="14,0,0,0"/>
                        </Grid>
                        <Grid Grid.Row="1" Margin="0,10,0,8">
                            <TextBox Text="{Binding GamerMode.DiscoverySearchText, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Search found games"
                                     AutomationProperties.Name="Search found games"/>
                            <TextBlock Text="Search found games" Margin="9,0"
                                       VerticalAlignment="Center" IsHitTestVisible="False"
                                       Foreground="{DynamicResource ThemeTextDim}" FontSize="10">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding GamerMode.DiscoverySearchText}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding GamerMode.DiscoverySearchText}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                        <ListBox Grid.Row="2" x:Name="DiscoveredGamesList"
                                 ItemsSource="{Binding GamerMode.FilteredDiscoveredGames}"
                                 Background="{DynamicResource ThemeBg}" BorderBrush="{DynamicResource ThemeBorder}"
                                 BorderThickness="1" ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.CanContentScroll="True"
                                 VirtualizingPanel.IsVirtualizing="True"
                                 VirtualizingPanel.VirtualizationMode="Recycling">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="{DynamicResource ThemeText}"/>
                                    <Setter Property="Padding" Value="5,2"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" Margin="4,5">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding DisplayName}" FontFamily="{StaticResource DisplayFont}"
                                                           FontWeight="Bold" FontSize="11" Foreground="{DynamicResource ThemeText}"/>
                                                <TextBlock Text="{Binding ExecutableName}" FontFamily="{StaticResource MonoFont}"
                                                           FontSize="9" Foreground="{DynamicResource ThemeTextDim}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                        VerticalAlignment="Center" Margin="18,0,2,0">
                                                <Border BorderBrush="{DynamicResource ThemeAccent}" BorderThickness="1"
                                                        Padding="5,2" Margin="0,0,8,0"
                                                        Visibility="{Binding HasDetectedHdr, Converter={StaticResource BoolToVis}}"
                                                        ToolTip="{Binding HdrEvidence}">
                                                    <TextBlock Text="HDR FOUND" Style="{StaticResource FieldLabel}"
                                                               Foreground="{DynamicResource ThemeAccent}"/>
                                                </Border>
                                                <TextBlock Text="{Binding Library}" Style="{StaticResource FieldLabel}"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Grid>
                                    </CheckBox>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <Grid Grid.Row="3" Margin="0,9,0,0">
                            <TextBlock Text="Selected games receive the Competitive look and can be tuned individually."
                                       FontSize="9" Foreground="{DynamicResource ThemeTextDim}"
                                       VerticalAlignment="Center"/>
                            <Button Content="{Binding GamerMode.AddDiscoveredButtonLabel}"
                                    Command="{Binding AddDiscoveredGamesCommand}"
                                    Style="{StaticResource BrutBtnPrimary}" HorizontalAlignment="Right"/>
                        </Grid>
                    </Grid>
                </Border>

                <Grid Grid.Row="2" Margin="2,9,2,0">
                    <TextBlock Text="{Binding GamerMode.EditorStatus}"
                               FontFamily="{StaticResource MonoFont}" FontSize="9"
                               Foreground="{DynamicResource ThemeTextDim}"/>
                    <TextBlock Text="Esc closes  ·  Win + Shift + F4 clears display changes and pauses Game Mode"
                               HorizontalAlignment="Right" FontSize="9"
                               Foreground="{DynamicResource ThemeTextDim}"/>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
